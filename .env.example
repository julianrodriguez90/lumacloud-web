# Resend — envío del formulario de contacto (https://resend.com)
RESEND_API_KEY=

# Google Analytics 4 (opcional; si está vacío no se inyecta GA)
PUBLIC_GA4_ID=

# Zoho CRM (self-client OAuth) — leads del sitio → módulo Leads
# Crear Self Client en https://api-console.zoho.com con scope ZohoCRM.modules.leads.CREATE
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
# Solo si el DC de la cuenta NO es .com:
# ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
# ZOHO_API_URL=https://www.zohoapis.com

# Opcionales: API names de campos personalizados del módulo Leads.
# Si no se configuran, el mismo contexto permanece en Description.
# ZOHO_FIELD_FORM_SOURCE=Fuente_del_formulario
# ZOHO_FIELD_SERVICE=Servicio_de_interes
# ZOHO_FIELD_TOOL_RESULT=Resultado_de_herramienta
# ZOHO_FIELD_LANDING_PAGE=Landing_page
# ZOHO_FIELD_LAST_TOUCH_PAGE=Ultima_pagina
# ZOHO_FIELD_CTA=CTA_de_conversion
# ZOHO_FIELD_LCI_PLAN=Plan_LCI
# ZOHO_FIELD_LCI_MODALITY=Modalidad_LCI
