---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTASection from '@/components/CTASection.astro';
import FAQSection from '@/components/FAQSection.astro';
import { SITE } from '@/lib/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const CATEGORIA_SERVICIO: Record<string, { href: string; label: string }> = {
  ciberseguridad: { href: '/ciberseguridad', label: 'Ciberseguridad administrada' },
  backup: { href: '/backup', label: 'Backup y ciberrecuperación' },
  cloud: { href: '/cloud', label: 'Cloud e infraestructura' },
  soc: { href: '/soc', label: 'SOC 24/7' },
  educacion: { href: '/ciberseguridad', label: 'Ciberseguridad administrada' },
};

const CATEGORIA_RECURSO: Record<string, { href: string; label: string }> = {
  ciberseguridad: { href: '/herramientas/evaluacion-ciberseguridad', label: 'Evalúa la madurez de tu empresa' },
  backup: { href: '/herramientas/calculadora-rto-rpo', label: 'Calcula tus objetivos RTO y RPO' },
  cloud: { href: '/herramientas/calculadora-costo-downtime', label: 'Calcula el costo de una interrupción' },
  soc: { href: '/herramientas/evaluacion-ciberseguridad', label: 'Identifica tus brechas prioritarias' },
  educacion: { href: '/herramientas/test-phishing', label: 'Pon a prueba tu detección de phishing' },
};

const servicio = CATEGORIA_SERVICIO[post.data.category];
const recurso = CATEGORIA_RECURSO[post.data.category];
const canonicalPath = `/blog/${post.id.replace(/\.md$/, '')}`;
const authorUrl = post.data.authorUrl || '/politica-editorial';

// relacionados: misma categoría, más recientes
const relacionados = (await getCollection('blog'))
  .filter((p) => p.id !== post.id && p.data.category === post.data.category)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const articleSchema = {
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.seoDescription,
  datePublished: post.data.publishDate.toISOString(),
  dateModified: post.data.updatedDate.toISOString(),
  author: {
    '@type': post.data.author === 'Equipo LumaCloud' ? 'Organization' : 'Person',
    name: post.data.author,
    url: new URL(authorUrl, SITE.url).href,
  },
  reviewedBy: post.data.reviewedBy
    ? {
        '@type': 'Person',
        name: post.data.reviewedBy.name,
        jobTitle: post.data.reviewedBy.role,
        url: post.data.reviewedBy.url ? new URL(post.data.reviewedBy.url, SITE.url).href : undefined,
      }
    : undefined,
  publisher: { '@id': `${SITE.url}/#organization` },
  image: post.data.image ? new URL(post.data.image, SITE.url).href : undefined,
  mainEntityOfPage: new URL(canonicalPath, SITE.url).href,
};

const fmt = (d: Date) => d.toLocaleDateString('es-CO', { day: 'numeric', month: 'long', year: 'numeric' });
---

<BaseLayout
  title={post.data.seoTitle}
  description={post.data.seoDescription}
  ogImage={post.data.image}
  breadcrumbs={[
    { name: 'Inicio', href: '/' },
    { name: 'Blog', href: '/blog' },
    { name: post.data.title, href: canonicalPath },
  ]}
  schemas={[articleSchema]}
>
  <article>
    <header class="bg-blueprint bg-hero-mesh border-b border-frost-200">
      <div class="mx-auto max-w-4xl px-4 py-14 sm:px-6">
        <nav class="text-sm text-ink-mute" aria-label="Miga de pan">
          <a href="/blog" class="font-medium text-mid-600 hover:underline">← Volver al blog</a>
        </nav>
        <h1 class="mt-6 text-3xl font-bold leading-tight text-ink sm:text-4xl lg:text-[2.75rem]">{post.data.title}</h1>
        <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-ink-mute">
          <a href={authorUrl} class="inline-flex min-h-11 items-center font-medium text-ink-soft hover:text-mid-600">{post.data.author}</a>
          {post.data.reviewedBy && <span>Revisión técnica: {post.data.reviewedBy.name} · {post.data.reviewedBy.role}</span>}
          <time datetime={post.data.publishDate.toISOString()}>{fmt(post.data.publishDate)}</time>
          {
            post.data.updatedDate.valueOf() !== post.data.publishDate.valueOf() && (
              <span>Actualizado: {fmt(post.data.updatedDate)}</span>
            )
          }
        </div>
      </div>
    </header>

    {
      post.data.image && (
        <div class="mx-auto max-w-4xl px-4 sm:px-6">
          <img
            src={post.data.image}
            alt={post.data.imageAlt ?? post.data.title}
            width={1400}
            height={800}
            fetchpriority="high"
            class="-mt-0 aspect-[16/9] w-full rounded-b-2xl object-cover shadow-[0_20px_50px_rgb(23_58_135/0.12)] sm:-mt-2"
          />
        </div>
      )
    }

    <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
      <div class="prose-luma mx-auto">
        <Content />
      </div>

      {
        servicio && (
          <aside class="card-brand mx-auto mt-14 max-w-2xl p-8 text-center">
            <div class="mx-auto w-14 brand-rule" />
            <h2 class="font-display mt-4 text-3xl text-cold-600">¿Necesitas ayuda con esto?</h2>
            <p class="mt-3 text-ink-soft">
              Nuestro equipo gestiona la seguridad y la infraestructura de empresas colombianas todos los días.
            </p>
            <div class="mt-6 flex flex-col justify-center gap-3 sm:flex-row">
              <a
                href={recurso.href}
                data-track="cta_click"
                data-track-cta={`blog-tool-${post.data.category}`}
                class="flex min-h-11 items-center justify-center rounded-xl bg-mid-500 px-7 py-3 font-semibold text-white shadow-[0_6px_20px_rgb(0_115_255/0.35)] transition-all hover:-translate-y-0.5 hover:bg-mid-600"
              >
                {recurso.label}
              </a>
              <a
                href={servicio.href}
                data-track="cta_click"
                data-track-cta={`blog-service-${post.data.category}`}
                class="flex min-h-11 items-center justify-center rounded-xl border border-frost-300 px-7 py-3 font-semibold text-cold-600 transition-colors hover:border-mid-400 hover:text-mid-600"
              >
                Conoce {servicio.label}
              </a>
            </div>
          </aside>
        )
      }
    </div>
  </article>

  {post.data.faqs && <FAQSection faqs={post.data.faqs} />}

  {
    relacionados.length > 0 && (
      <section class="border-t border-frost-200 bg-frost-50 py-16">
        <div class="mx-auto max-w-7xl px-4 sm:px-6">
          <h2 class="font-display text-3xl text-cold-600 sm:text-4xl">Artículos relacionados</h2>
          <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {relacionados.map((p) => (
              <a href={`/blog/${p.id.replace(/\.md$/, '')}`} class="card-brand group flex flex-col overflow-hidden">
                {p.data.image && (
                  <img
                    src={p.data.image}
                    alt={p.data.imageAlt ?? p.data.title}
                    width={700}
                    height={400}
                    loading="lazy"
                    class="h-40 w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                )}
                <div class="flex flex-1 flex-col p-6">
                  <h3 class="flex-1 font-bold leading-snug text-ink group-hover:text-mid-600">{p.data.title}</h3>
                  <p class="mt-3 text-sm text-ink-mute">{fmt(p.data.publishDate)}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <CTASection />
</BaseLayout>
