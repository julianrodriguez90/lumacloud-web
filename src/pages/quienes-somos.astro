---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BrandImage from '@/components/BrandImage.astro';
import CTASection from '@/components/CTASection.astro';
import FAQSection from '@/components/FAQSection.astro';
import Testimonios from '@/components/Testimonios.astro';
import { SITE } from '@/lib/site';

const title = 'Quiénes Somos | LumaCloud';
const description =
  'Conoce el propósito, la misión y el ecosistema Luma 360 con el que protegemos la continuidad operativa de empresas en Latinoamérica.';

const VALORES = [
  { nombre: 'Pasión', texto: 'Disfrutamos lo que hacemos.' },
  { nombre: 'Curiosidad', texto: 'Estudiamos constantemente.' },
  { nombre: 'Acción', texto: 'Hacemos que las cosas pasen.' },
  { nombre: 'Innovación', texto: 'Creamos soluciones nuevas para problemas simples o complejos.' },
  { nombre: 'Compromiso', texto: 'Entregamos lo mejor de nosotros al equipo y al cliente.' },
];

const ECOSISTEMA = [
  { nombre: 'Infraestructura resiliente', texto: 'Nube de alta disponibilidad para sostener las aplicaciones y datos que mantienen tu operación.' },
  { nombre: 'Defensa proactiva', texto: 'Capas de ciberprotección y monitoreo para identificar anomalías y responder con agilidad.' },
  { nombre: 'Recuperación', texto: 'Sistemas de ciberrecuperación y DRP para restaurar la operación ante un incidente.' },
  { nombre: 'Servicios profesionales', texto: 'DBA, arquitectos e ingenieros de seguridad que acompañan las necesidades de tu equipo.' },
];

const TECNOLOGIAS = ['Google Cloud', 'Vicarius', 'Microsoft'];

const ORGANIZACIONES = [
  'Seguros APS',
  'Vivienda (Ministerio de Vivienda)',
  'IDU (Instituto de Desarrollo Urbano)',
  'Universidad de Manizales',
  'Domoteq',
  'La Terminal (Terminal de Transporte de Bogotá)',
  'Takami',
  'Suma',
  'Centro de Investigación Clínica de la Costa',
  'Itaú',
  'CNE (Consejo Nacional Electoral)',
  'Mass',
  'Torortiz',
  'Icontec',
  'Amarilo',
  'SuPiscina',
  'AssisPrex',
  'Ana María',
  'Ecopetrol',
  'Ejército Nacional de Colombia',
  'Energía Integral Andina',
  'SENA',
  'Canal RCN',
];

const PROPUESTA = [
  {
    numero: '01',
    nombre: 'Continuidad operativa proactiva',
    texto: 'El CyberSOC monitorea amenazas y la salud de servicios críticos, como bases de datos, aplicativos y componentes de red, para detectar señales de falla y coordinar una respuesta en minutos.',
    puntos: ['Monitoreo de capa crítica', 'Detección de comportamientos anómalos', 'Inteligencia de Google, Mandiant, VirusTotal, Fortinet y Vicarius'],
  },
  {
    numero: '02',
    nombre: 'Resiliencia técnica de clase mundial',
    texto: 'La infraestructura se apoya en datacenters TIER III y IV, arquitectura hiperconvergente y capacidades de ciberrecuperación para reducir puntos únicos de falla.',
    puntos: ['Datacenters TIER III y IV', 'Arquitectura hiperconvergente', 'Recuperación ágil ante desastres'],
  },
  {
    numero: '03',
    nombre: 'Estabilidad financiera y transparencia',
    texto: 'Una nube sin sorpresas: costos previsibles, escalabilidad lineal y una arquitectura local que puede reducir costos hasta en un 40% frente a nubes internacionales.',
    puntos: ['Sin costos ocultos de red', 'Precios accesibles y estables', 'Escalabilidad inmediata de recursos'],
  },
  {
    numero: '04',
    nombre: 'Soberanía y alianza estratégica regional',
    texto: 'La información permanece en la región y un equipo experto acompaña la operación como extensión del equipo del cliente, desde la migración hasta el soporte continuo.',
    puntos: ['Datos alojados en la región', 'Acompañamiento experto 360', 'Migración gratuita al ecosistema'],
  },
];

const FAQS = [
  {
    q: '¿Qué hace LumaCloud?',
    a: 'Integramos infraestructura de nube, ciberprotección, ciberrecuperación y servicios profesionales en el ecosistema Luma 360 para respaldar la continuidad operativa de las organizaciones.',
  },
  {
    q: '¿Qué problema resuelve LumaCloud?',
    a: 'Ayudamos a eliminar la fragmentación entre infraestructura, seguridad y recuperación. El cliente cuenta con un solo aliado que entiende la operación completa y coordina la respuesta ante un desafío digital.',
  },
  {
    q: '¿Qué es el CyberSOC de LumaCloud?',
    a: 'Es el centro operativo que monitorea amenazas de seguridad y la salud de servicios críticos, como bases de datos, aplicativos y componentes de red, para detectar anomalías y responder con agilidad.',
  },
  {
    q: '¿Cuál es el propósito de LumaCloud?',
    a: 'Hacer que las empresas sean imparables ante cualquier desafío digital.',
  },
  {
    q: '¿Dónde está ubicada LumaCloud?',
    a: `Nuestra sede está en la ${SITE.address.street}, Bogotá D.C., Colombia. Atendemos a las empresas con soporte 24/7.`,
  },
];

const aboutSchema = {
  '@type': 'AboutPage',
  '@id': `${SITE.url}/quienes-somos#aboutpage`,
  url: `${SITE.url}/quienes-somos`,
  name: 'Quiénes Somos — LumaCloud',
  description,
  mainEntity: { '@id': `${SITE.url}/#organization` },
};
---

<BaseLayout
  {title}
  {description}
  breadcrumbs={[
    { name: 'Inicio', href: '/' },
    { name: 'Quiénes somos', href: '/quienes-somos' },
  ]}
  schemas={[aboutSchema]}
>
    <section class="bg-blueprint bg-hero-mesh relative overflow-hidden border-b border-frost-200">
      <div class="mx-auto grid max-w-7xl items-center gap-12 px-4 pb-16 pt-14 sm:px-6 lg:grid-cols-[1.05fr_1fr] lg:pb-24 lg:pt-20">
        <div class="animate-rise">
          <nav class="text-sm text-ink-mute" aria-label="Miga de pan">
            <a href="/" class="flex min-h-11 min-w-11 items-center hover:text-mid-600">Inicio</a>
            <span class="sr-only">/</span>
            <span class="font-medium text-cold-600">Quiénes somos</span>
          </nav>
          <p class="mt-4 text-sm font-semibold uppercase tracking-[0.2em] text-mid-500">Continuidad operativa · Ecosistema Luma 360</p>
          <h1 class="font-display mt-4 text-5xl leading-[0.95] text-ink sm:text-6xl lg:text-7xl">
            Hacemos que las empresas sean <span class="text-brand-gradient">imparables</span>
          </h1>
          <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-soft">
            Somos un aliado estratégico que integra infraestructura, defensa y recuperación para que la tecnología de tu empresa opere
            como un solo ecosistema.
          </p>
          <div class="mt-8 flex flex-col gap-4 sm:flex-row">
            <a href="/contacto" data-track="cta_click" data-track-cta="quienes-hero" class="flex min-h-11 items-center justify-center rounded-xl bg-mid-500 px-8 py-3 font-semibold text-white shadow-[0_8px_30px_rgb(0_115_255/0.35)] transition-all hover:-translate-y-0.5 hover:bg-mid-600">Conversemos de tu operación</a>
            <a href="#luma-360" class="flex min-h-11 items-center justify-center rounded-xl border border-frost-300 bg-white/75 px-8 py-3 font-semibold text-cold-600 transition-colors hover:border-mid-400 hover:text-mid-600">Conoce Luma 360</a>
          </div>
        </div>
        <div class="relative animate-rise [animation-delay:0.15s]">
          <BrandImage
            src="/images/nosotros/equipo-1.webp"
            alt="Equipo de LumaCloud trabajando en soluciones de continuidad operativa"
            width={1000}
            height={668}
            overlay
            priority
          />
          <div class="absolute -bottom-6 -left-4 max-w-[16rem] rounded-2xl border border-sky-300 bg-white px-5 py-4 shadow-lg sm:-left-7">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-mid-500">Nuestro propósito</p>
            <p class="mt-2 text-sm font-semibold leading-relaxed text-cold-600">Hacer que las empresas sean imparables ante cualquier desafío digital.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-blueprint-dark bg-cold-900 py-16 text-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6">
        <div class="grid gap-10 lg:grid-cols-[0.7fr_1.3fr] lg:items-center">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-500">Nuestra experiencia</p>
            <h2 class="font-display mt-3 text-4xl leading-tight sm:text-5xl">Experiencia regional para proteger operaciones críticas</h2>
            <div class="mt-4 w-16 brand-rule"></div>
            <p class="mt-5 max-w-lg leading-relaxed text-white/70">
              Combinamos infraestructura, ciberseguridad, talento experto e inteligencia artificial para acompañar la continuidad operativa
              de empresas en Latinoamérica.
            </p>
          </div>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            <article class="rounded-2xl border border-white/15 bg-white/[0.06] p-6">
              <p class="font-display text-5xl text-sky-500">+11</p>
              <p class="mt-2 font-semibold text-white">Años de experiencia</p>
            </article>
            <article class="rounded-2xl border border-white/15 bg-white/[0.06] p-6">
              <p class="font-display text-5xl text-sky-500">+6</p>
              <p class="mt-2 font-semibold text-white">Países con experiencia</p>
            </article>
            <article class="rounded-2xl border border-white/15 bg-white/[0.06] p-6">
              <p class="font-display text-3xl text-sky-500">TIER III / IV</p>
              <p class="mt-2 font-semibold text-white">Datacenters empresariales</p>
            </article>
            <article class="rounded-2xl border border-white/15 bg-white/[0.06] p-6">
              <p class="font-display text-3xl text-sky-500">CyberSOC</p>
              <p class="mt-2 font-semibold text-white">Monitoreo y equipo experto</p>
            </article>
            <article class="rounded-2xl border border-white/15 bg-white/[0.06] p-6">
              <p class="font-display text-3xl text-sky-500">IA</p>
              <p class="mt-2 font-semibold text-white">Inteligencia artificial para empresas</p>
            </article>
            <article class="rounded-2xl border border-white/15 bg-white/[0.06] p-6">
              <p class="font-display text-3xl text-sky-500">ISO 27001</p>
              <p class="mt-2 font-semibold text-white">Controles técnicos y acompañamiento</p>
            </article>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white py-16 sm:py-20" aria-labelledby="experiencia-clientes-title">
      <div class="mx-auto max-w-7xl px-4 sm:px-6">
        <div class="mx-auto max-w-3xl text-center">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-mid-500">Nuestra experiencia</p>
          <h2 id="experiencia-clientes-title" class="font-display mt-3 text-4xl text-cold-600 sm:text-5xl">
            Tecnología, cobertura regional y organizaciones
          </h2>
          <div class="brand-rule mx-auto mt-3 w-16"></div>
        </div>

        <div class="mt-10 overflow-hidden rounded-[2rem] border border-frost-300 bg-frost-50 shadow-card">
          <div class="border-b border-frost-300 bg-white px-6 py-8 sm:px-10">
            <p class="text-center text-xs font-semibold uppercase tracking-[0.24em] text-ink-mute">Tecnología de clase mundial</p>
            <ul class="mt-6 grid gap-4 sm:grid-cols-3" aria-label="Tecnologías con las que trabaja LumaCloud">
              {TECNOLOGIAS.map((tecnologia) => (
                <li class="font-display flex min-h-16 items-center justify-center border-y border-frost-300 px-4 text-center text-2xl tracking-wide text-cold-600 sm:text-3xl">
                  {tecnologia}
                </li>
              ))}
            </ul>
          </div>

          <div class="grid lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
            <figure class="bg-white p-5 sm:p-8 lg:border-r lg:border-frost-300">
              <img
                src="/images/nosotros/mapa-experiencia-regional.webp"
                alt="Mapa de experiencia regional de LumaCloud en Colombia, Ecuador, República Dominicana, Perú, México y Chile"
                width="1010"
                height="1290"
                loading="lazy"
                decoding="async"
                class="mx-auto h-auto w-full max-w-[34rem]"
              />
              <figcaption class="sr-only">
                Cobertura de experiencia regional presentada por el cliente para Colombia, Ecuador, República Dominicana, Perú, México y Chile.
              </figcaption>
            </figure>

            <div class="border-t border-frost-300 px-6 py-9 sm:px-10 lg:border-t-0">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-mid-500">Organizaciones</p>
              <h3 class="font-display mt-3 text-3xl leading-tight text-cold-600 sm:text-4xl">
                Nombres que hacen parte de nuestra experiencia
              </h3>
              <p class="mt-4 max-w-2xl text-sm leading-relaxed text-ink-soft">
                Presentamos los nombres en formato textual, de acuerdo con la autorización vigente para este contenido.
              </p>
              <ul class="mt-7 grid gap-x-7 sm:grid-cols-2" aria-label="Organizaciones que hacen parte de la experiencia de LumaCloud">
                {ORGANIZACIONES.map((organizacion) => (
                  <li class="flex min-h-11 items-center gap-3 border-b border-frost-300 py-2.5 text-sm font-semibold leading-snug text-cold-700">
                    <span class="h-2.5 w-2.5 shrink-0 rounded-full bg-sky-500" aria-hidden="true"></span>
                    <span>{organizacion}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div class="scroll-reveal">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-mid-500">Concepto de negocio</p>
          <h2 class="font-display mt-3 text-4xl text-cold-600 sm:text-5xl">Un solo aliado para una operación que no se detiene</h2>
          <div class="mt-3 w-16 brand-rule"></div>
          <div class="mt-6 space-y-4 leading-relaxed text-ink-soft">
            <p>
              LumaCloud es un aliado estratégico especializado en la continuidad operativa de las organizaciones a través de un ecosistema
              integral denominado Luma 360.
            </p>
            <p>
              Integramos infraestructura de nube de alta disponibilidad, capas avanzadas de ciberprotección, sistemas de recuperación ante
              desastres y servicios profesionales expertos. Todo es orquestado por un CyberSOC de nueva generación que observa tanto las
              amenazas como la salud de los servicios críticos.
            </p>
          </div>
        </div>
        <div class="scroll-reveal rounded-[2rem] bg-cold-900 p-7 text-white shadow-[0_20px_60px_rgb(23_58_135/0.24)] sm:p-9">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-500">El problema que resolvemos</p>
          <p class="font-display mt-4 text-3xl leading-tight sm:text-4xl">Eliminamos la fragmentación tecnológica y reducimos el riesgo de parálisis operativa.</p>
          <p class="mt-5 leading-relaxed text-white/70">Cuando infraestructura y seguridad no se hablan entre sí, una caída o pérdida de datos afecta el negocio completo. LumaCloud conecta esas capacidades y asume un único punto de contacto y responsabilidad.</p>
        </div>
      </div>
    </section>

    <section id="luma-360" class="bg-frost-50 py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6">
        <div class="mx-auto max-w-3xl text-center">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-mid-500">Ecosistema Luma 360</p>
          <h2 class="font-display mt-3 text-4xl text-cold-600 sm:text-5xl">Infraestructura, defensa y recuperación en una sola mente operativa</h2>
          <div class="mx-auto mt-3 w-16 brand-rule"></div>
        </div>
        <div class="relative mt-12 grid gap-5 md:grid-cols-2">
          {ECOSISTEMA.map((item) => (
            <article class="card-brand scroll-reveal p-7">
              <h3 class="text-xl font-semibold text-cold-600">{item.nombre}</h3>
              <p class="mt-3 text-sm leading-relaxed text-ink-soft">{item.texto}</p>
            </article>
          ))}
          <div class="pointer-events-none absolute left-1/2 top-1/2 hidden h-36 w-36 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full border-8 border-frost-50 bg-gradient-to-br from-cold-600 to-mid-500 text-center text-sm font-bold text-white shadow-glow md:flex" aria-hidden="true">CYBER<br />SOC</div>
        </div>
      </div>
    </section>

    <section class="bg-blueprint-dark bg-ink py-20 text-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6">
        <div class="grid gap-6 lg:grid-cols-2">
          <article class="scroll-reveal rounded-[2rem] border border-white/15 bg-white/[0.06] p-7 sm:p-9">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-500">Misión</p>
            <h2 class="font-display mt-4 text-4xl">Garantizar la continuidad operativa</h2>
            <p class="mt-5 leading-relaxed text-white/70">mediante un ecosistema 360 que integra infraestructura resiliente, defensa proactiva y recuperación ágil.</p>
          </article>
          <article class="scroll-reveal rounded-[2rem] border border-white/15 bg-white/[0.06] p-7 sm:p-9">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-500">Visión</p>
            <h2 class="font-display mt-4 text-4xl">Mayor impacto regional para 2030</h2>
            <p class="mt-5 leading-relaxed text-white/70">Ser la compañía de infraestructura y ciberseguridad con mayor impacto regional para 2030, definiendo el estándar de continuidad operativa para el mercado.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-mid-500">Valores ADN Luma</p>
        <h2 class="font-display mt-3 text-4xl text-cold-600 sm:text-5xl">Cómo actuamos cada día</h2>
        <div class="mx-auto mt-3 w-16 brand-rule"></div>
      </div>
      <div class="stagger mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-5">
        {VALORES.map((valor, index) => (
          <article class="card-brand scroll-reveal p-6">
            <span class="font-display text-3xl text-sky-600">0{index + 1}</span>
            <h3 class="mt-4 text-xl font-semibold text-cold-600">{valor.nombre}</h3>
            <p class="mt-3 text-sm leading-relaxed text-ink-soft">{valor.texto}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="bg-frost-50 py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-mid-500">Propuesta de valor extendida</p>
          <h2 class="font-display mt-3 text-4xl text-cold-600 sm:text-5xl">La continuidad operativa se construye en cuatro frentes</h2>
          <div class="mt-3 w-16 brand-rule"></div>
        </div>
        <div class="mt-12 space-y-6">
          {PROPUESTA.map((item) => (
            <article class="scroll-reveal grid gap-6 rounded-[2rem] border border-frost-300 bg-white p-7 shadow-card md:grid-cols-[5rem_1fr_0.9fr] md:items-start sm:p-9">
              <span class="font-display text-5xl text-sky-600">{item.numero}</span>
              <div>
                <h3 class="font-display text-3xl text-cold-600">{item.nombre}</h3>
                <p class="mt-4 leading-relaxed text-ink-soft">{item.texto}</p>
              </div>
              <ul class="space-y-3 border-t border-frost-200 pt-5 md:border-l md:border-t-0 md:pl-7 md:pt-0">
                {item.puntos.map((punto) => <li class="flex gap-3 text-sm text-ink-soft"><span class="text-mid-500" aria-hidden="true">✓</span>{punto}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-5xl px-4 py-20 text-center sm:px-6">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-mid-500">Lo que realmente entregamos</p>
      <blockquote class="font-display mt-5 text-4xl leading-tight text-cold-600 sm:text-5xl">“No vendemos servidores ni antivirus. Vendemos la certeza de que tu negocio funcionará mañana igual que hoy.”</blockquote>
      <p class="mx-auto mt-6 max-w-3xl leading-relaxed text-ink-soft">Integramos defensa, infraestructura y recuperación en una sola mente operativa —el CyberSOC— que trabaja para anticiparse al problema.</p>
    </section>

    <Testimonios />
    <FAQSection faqs={FAQS} />
    <CTASection title="Construyamos una operación imparable" text="Cuéntanos qué necesita proteger, sostener o recuperar tu empresa. Diseñamos contigo un ecosistema Luma 360 a la medida." ctaLabel="Habla con nuestro equipo" />
</BaseLayout>
