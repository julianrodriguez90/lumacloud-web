---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BrandImage from '@/components/BrandImage.astro';
import CTASection from '@/components/CTASection.astro';
import FAQSection from '@/components/FAQSection.astro';
import { SITE } from '@/lib/site';

const title = 'ISO 27001 en Colombia: Consultoría y Cumplimiento | LumaCloud';
const description =
  'Prepara tu SGSI para la certificación ISO 27001:2022: implementamos los controles del Anexo A — backup, cifrado, monitoreo SOC y gestión de accesos.';

const CONTROLES = [
  {
    nombre: 'Backup y continuidad',
    texto:
      'La norma exige respaldar la información y garantizar su disponibilidad ante incidentes. Implementamos backup empresarial y recuperación ante desastres con evidencia verificable para tu auditoría.',
  },
  {
    nombre: 'Cifrado de la información',
    texto:
      'Protección criptográfica de los datos en tránsito y en reposo, uno de los controles tecnológicos del Anexo A que más pesa en la evaluación de un SGSI.',
  },
  {
    nombre: 'Monitoreo y registro de eventos',
    texto:
      'El Anexo A pide registrar, correlacionar y revisar eventos de seguridad. Nuestro SOC 24/7 con SIEM cubre este control de forma continua y deja trazabilidad para el auditor.',
  },
  {
    nombre: 'Gestión de accesos e identidades',
    texto:
      'Control de acceso basado en roles, autenticación reforzada y revisión periódica de privilegios: quién accede a qué, cuándo y con qué justificación.',
  },
  {
    nombre: 'DLP — Prevención de fuga de datos',
    texto:
      'Directivas de prevención de fuga sobre dispositivos y comunicaciones de red, alineadas con los controles de protección de la información del Anexo A.',
  },
  {
    nombre: 'Gestión de vulnerabilidades',
    texto:
      'Identificación de sistemas expuestos a vulnerabilidades críticas y acciones de remediación documentadas: insumo directo para la mejora continua del SGSI.',
  },
];

const FAQS = [
  {
    q: '¿LumaCloud emite la certificación ISO 27001?',
    a: 'No. La certificación la otorga un organismo de certificación acreditado tras auditar tu SGSI. Lo que hacemos en LumaCloud es implementar y operar los controles técnicos que la norma exige — backup, cifrado, monitoreo, gestión de accesos, DLP — para que llegues a esa auditoría con evidencia sólida.',
  },
  {
    q: '¿Qué es un SGSI?',
    a: 'Un Sistema de Gestión de Seguridad de la Información: el conjunto de políticas, procesos y controles con los que tu organización identifica sus riesgos de seguridad y los gestiona de forma sistemática. Es el corazón de ISO 27001 y funciona con un ciclo de mejora continua: planificar, implementar, verificar y mejorar.',
  },
  {
    q: '¿Qué son los controles del Anexo A?',
    a: 'El Anexo A de ISO 27001:2022 es el catálogo de controles de referencia de la norma, organizado en cuatro temas: organizacionales, de personas, físicos y tecnológicos. Tras el análisis de riesgos, tu empresa selecciona los controles aplicables y lo documenta en la Declaración de Aplicabilidad.',
  },
  {
    q: '¿Cómo funciona el ciclo de certificación?',
    a: 'La auditoría de certificación se realiza en dos etapas: una revisión documental del SGSI y una auditoría de implementación. El certificado tiene una vigencia de tres años, con auditorías de seguimiento anuales y una recertificación al final del ciclo.',
  },
  {
    q: '¿Qué relación hay entre ISO 27001 y la Ley 1581?',
    a: 'La Ley 1581 de 2012 obliga a proteger los datos personales que tratas en Colombia, y muchos de los controles de ISO 27001 — cifrado, accesos, respaldo, gestión de incidentes — sirven como medidas para demostrar ese deber de seguridad. Si trabajas ambos marcos a la vez, avanzas el doble con el mismo esfuerzo.',
  },
];

const serviceSchema = {
  '@type': 'Service',
  name: 'Implementación de controles técnicos ISO 27001',
  serviceType: 'Consultoría y cumplimiento ISO 27001',
  provider: { '@id': `${SITE.url}/#organization` },
  areaServed: 'Colombia',
  description,
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Controles técnicos para ISO 27001',
    itemListElement: CONTROLES.map((s) => ({
      '@type': 'Offer',
      itemOffered: { '@type': 'Service', name: s.nombre },
    })),
  },
};
---

<BaseLayout
  {title}
  {description}
  breadcrumbs={[
    { name: 'Inicio', href: '/' },
    { name: 'Cumplimiento', href: '/cumplimiento/iso-27001' },
    { name: 'ISO 27001', href: '/cumplimiento/iso-27001' },
  ]}
  schemas={[serviceSchema]}
>
  <!-- HERO -->
  <section class="bg-blueprint bg-hero-mesh relative overflow-hidden border-b border-frost-200">
    <div class="mx-auto grid max-w-7xl items-center gap-12 px-4 pb-16 pt-14 sm:px-6 lg:grid-cols-[1.15fr_1fr] lg:pb-24 lg:pt-20">
      <div class="animate-rise">
        <nav class="text-sm text-ink-mute" aria-label="Miga de pan">
          <a href="/" class="hover:text-mid-600">Inicio</a>
          <span class="mx-2">/</span>
          <span>Cumplimiento</span>
          <span class="mx-2">/</span>
          <span class="font-medium text-cold-600">ISO 27001</span>
        </nav>
        <h1 class="font-display mt-5 text-5xl leading-[0.95] text-ink sm:text-6xl lg:text-7xl">
          <span class="text-brand-gradient">ISO 27001</span> en Colombia
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-soft">
          Un certificado ISO 27001 se gana con controles que funcionan, no con carpetas de políticas. Implementamos y operamos los controles
          técnicos que tu SGSI necesita para pasar la auditoría: backup, cifrado, monitoreo SOC y gestión de accesos.
        </p>
        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a
            href="/contacto"
            class="rounded-xl bg-mid-500 px-8 py-4 text-center font-semibold text-white shadow-[0_8px_30px_rgb(0_115_255/0.35)] transition-all hover:-translate-y-0.5 hover:bg-mid-600"
          >
            Habla con un experto
          </a>
          <a
            href="/soc"
            class="rounded-xl border border-frost-300 bg-white/70 px-8 py-4 text-center font-semibold text-cold-600 backdrop-blur transition-colors hover:border-mid-400 hover:text-mid-600"
          >
            Conoce nuestro SOC 24/7
          </a>
        </div>
      </div>
      <BrandImage
        src="/images/heros/servicios-profesionales.webp"
        alt="Consultores de seguridad de la información trabajando en el cumplimiento ISO 27001"
        width={1280}
        height={855}
        overlay
        priority
        class="animate-rise [animation-delay:0.15s]"
      />
    </div>
  </section>

  <!-- CONTROLES -->
  <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6">
    <p class="text-center mono-label text-mid-500">Controles del Anexo A</p>
    <h2 class="font-display mt-3 text-center text-4xl text-cold-600 sm:text-5xl">Los controles técnicos que exige la norma</h2>
    <div class="mx-auto mt-3 w-16 brand-rule"></div>

    <div class="scroll-reveal mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        CONTROLES.map((s) => (
          <div class="card-brand p-7">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br from-cold-600 to-mid-500 text-white">
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M10 2 3 5.5v5c0 4 3 6.5 7 7.5 4-1 7-3.5 7-7.5v-5L10 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                <path d="M7 10l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <h3 class="mt-5 text-lg font-bold text-ink">{s.nombre}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-mute">{s.texto}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- QUÉ ES / DETALLE -->
  <section class="bg-blueprint bg-frost-50 py-20">
    <div class="mx-auto grid max-w-7xl items-center gap-12 px-4 sm:px-6 lg:grid-cols-2">
      <div class="scroll-reveal">
        <h2 class="font-display text-4xl text-cold-600 sm:text-5xl">Del análisis de riesgos a la auditoría</h2>
        <div class="mt-3 w-16 brand-rule"></div>
        <div class="mt-6 space-y-4 text-base leading-relaxed text-ink-soft">
          <p>
            ISO 27001:2022 es el estándar internacional para gestionar la seguridad de la información. Su núcleo es el SGSI: identificas tus
            riesgos, seleccionas los controles del Anexo A que aplican a tu operación — organizacionales, de personas, físicos y
            tecnológicos — y demuestras que funcionan con evidencia.
          </p>
          <p>
            La certificación la otorga un organismo acreditado en una auditoría de dos etapas, el certificado dura tres años y cada año hay
            auditorías de seguimiento. Traducción: no basta con implementar una vez, hay que operar los controles todos los días.
          </p>
          <p>
            Ahí es donde entramos nosotros. LumaCloud no emite certificados: implementamos y operamos los controles técnicos — backup,
            cifrado, monitoreo con nuestro SOC, gestión de accesos, DLP — para que tu SGSI tenga sustento real y evidencia continua.
          </p>
        </div>
        <ul class="mt-8 space-y-3">
          {
            [
              'Controles tecnológicos del Anexo A operados por expertos',
              'Evidencia continua para auditorías de certificación y seguimiento',
              'Monitoreo SOC 24/7 que cubre el registro y revisión de eventos',
              'Una sola plataforma para backup, cifrado y protección de datos',
            ].map((b) => (
              <li class="flex items-start gap-3 text-ink">
                <span class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-mid-500 to-sky-500 text-white">
                  <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                    <path d="M2 6.5 4.5 9 10 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
                <span class="text-[0.95rem] font-medium">{b}</span>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="space-y-6">
        <BrandImage
          src="/images/heros/ciberseguridad-candado.webp"
          alt="Seguridad de la información: candado sobre un circuito digital"
          width={1280}
          height={800}
          overlay
          class="scroll-reveal"
        />
        <div class="card-brand p-7">
          <p class="font-display text-2xl text-cold-600">Dos marcos, un mismo esfuerzo</p>
          <p class="mt-2 text-sm leading-relaxed text-ink-mute">
            Los mismos controles que preparan tu certificación ISO 27001 — cifrado, accesos, respaldo, gestión de incidentes — te ayudan a
            demostrar el deber de seguridad que exige la Ley 1581 de protección de datos personales.
          </p>
          <a href="/cumplimiento/ley-1581" class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-mid-500 hover:text-mid-600">
            Ver cumplimiento Ley 1581
            <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M2 8h11M9 3l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ENLACES DE SILO -->
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6">
    <h2 class="font-display text-3xl text-cold-600 sm:text-4xl">Construye tu cumplimiento sobre bases sólidas</h2>
    <div class="mt-8 grid gap-5 sm:grid-cols-3">
      {
        [
          {
            href: '/cumplimiento/ley-1581',
            label: 'Cumplimiento Ley 1581',
            desc: 'Protección de datos personales en Colombia: habeas data, deberes y medidas de seguridad.',
          },
          {
            href: '/soc',
            label: 'SOC as a Service 24/7',
            desc: 'Monitoreo y registro de eventos de seguridad continuo: el control que nunca duerme.',
          },
          {
            href: '/ciberseguridad',
            label: 'Ciberseguridad administrada',
            desc: 'EDR, DLP, seguridad perimetral y email security para blindar tu operación.',
          },
        ].map((l) => (
          <a href={l.href} class="card-brand group p-7">
            <h3 class="font-bold text-ink group-hover:text-mid-600">{l.label}</h3>
            <p class="mt-2 text-sm text-ink-mute">{l.desc}</p>
            <span class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-mid-500">
              Ver más
              <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M2 8h11M9 3l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <FAQSection faqs={FAQS} />
  <CTASection
    title="Llega a tu auditoría con evidencia real"
    text="Cuéntanos en qué punto está tu SGSI y te proponemos un plan para implementar y operar los controles técnicos que la norma exige."
    ctaLabel="Habla con un experto"
  />
</BaseLayout>
