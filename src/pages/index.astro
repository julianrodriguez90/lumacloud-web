---
import Layout from '@/layouts/Layout.astro';
---
<Layout
  title="LumaCloud — Ciberseguridad y Nube Empresarial en Colombia"
  description="Soluciones de ciberseguridad, backup, cloud privado y SOC as a Service para empresas en Colombia. Protege tu negocio con LumaCloud."
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-brand-500 to-blue-800 text-white py-24 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-6">
        Ciberseguridad y nube empresarial<br class="hidden md:block" /> para Colombia
      </h1>
      <p class="text-lg text-blue-100 mb-8 max-w-2xl mx-auto">
        Protege tu empresa con soluciones de ciberseguridad administrada, backup en la nube,
        cloud privado y SOC 24/7. Más de 10 años protegiendo empresas en Colombia.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contacto" class="bg-white text-brand-500 hover:bg-blue-50 px-8 py-3 rounded-lg font-semibold transition">
          Solicita diagnóstico gratuito
        </a>
        <a href="/ciberseguridad" class="border border-white text-white hover:bg-white/10 px-8 py-3 rounded-lg font-semibold transition">
          Ver servicios
        </a>
      </div>
    </div>
  </section>

  <!-- Servicios -->
  <section class="max-w-6xl mx-auto px-4 py-20">
    <h2 class="text-3xl font-bold text-center mb-12">Nuestros servicios</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {[
        { title: 'Ciberseguridad', desc: 'Protección integral contra amenazas. Monitoreo, respuesta y remediación 24/7.', href: '/ciberseguridad', icon: '🛡️' },
        { title: 'Backup Empresarial', desc: 'Backup as a Service con RTO/RPO garantizados. Recuperación ante desastres.', href: '/backup', icon: '💾' },
        { title: 'Cloud Privado', desc: 'Infraestructura cloud en Colombia. Data center propio, alta disponibilidad.', href: '/cloud', icon: '☁️' },
        { title: 'SOC as a Service', desc: 'Centro de operaciones de seguridad 24/7. SIEM, monitoreo y gestión de incidentes.', href: '/soc', icon: '🔍' },
        { title: 'ISO 27001', desc: 'Acompañamiento para certificación ISO 27001 y cumplimiento Ley 1581.', href: '/cumplimiento/iso-27001', icon: '📋' },
        { title: 'Capacitación', desc: 'Concientización en ciberseguridad. Simulaciones de phishing para tu equipo.', href: '/herramientas/test-phishing', icon: '🎓' },
      ].map(s => (
        <a href={s.href} class="group border border-gray-200 rounded-xl p-6 hover:border-brand-500 hover:shadow-md transition-all">
          <div class="text-3xl mb-3">{s.icon}</div>
          <h3 class="text-lg font-semibold mb-2 group-hover:text-brand-500 transition">{s.title}</h3>
          <p class="text-gray-600 text-sm">{s.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Herramientas IA -->
  <section class="bg-gray-50 py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">Herramientas gratuitas</h2>
      <p class="text-gray-600 mb-10">Evalúa el estado de seguridad de tu empresa en minutos</p>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { title: 'Calculadora RTO/RPO', desc: 'Calcula el plan de backup ideal para tu empresa', href: '/herramientas/calculadora-rto-rpo' },
          { title: 'Evaluador ISO 27001', desc: 'Mide tu brecha de cumplimiento ISO 27001', href: '/herramientas/evaluador-iso-27001' },
          { title: 'Test de Phishing', desc: 'Evalúa la vulnerabilidad humana de tu equipo', href: '/herramientas/test-phishing' },
        ].map(h => (
          <a href={h.href} class="bg-white border border-gray-200 rounded-xl p-6 hover:border-brand-500 hover:shadow-md transition-all text-left">
            <h3 class="font-semibold mb-2">{h.title}</h3>
            <p class="text-sm text-gray-600 mb-4">{h.desc}</p>
            <span class="text-brand-500 text-sm font-medium">Usar gratis →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
