---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BrandImage from '@/components/BrandImage.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import DiagramStack from '@/components/DiagramStack.astro';
import DiagramRadar from '@/components/DiagramRadar.astro';
import Testimonios from '@/components/Testimonios.astro';
import CTASection from '@/components/CTASection.astro';
import FAQSection from '@/components/FAQSection.astro';
import { SERVICES } from '@/lib/nav';

const title = 'Ciberseguridad y Nube Empresarial en Colombia | LumaCloud';
const description =
  'Soluciones de ciberseguridad administrada, backup, cloud privado y SOC 24/7 para empresas en Colombia. Datacenters TIER III y IV, migración gratuita y soporte permanente.';

const DIFERENCIALES = [
  { titulo: 'Sin sorpresas en la factura', texto: 'Precios estables y escalabilidad lineal de recursos: más hardware, procesadores o almacenamiento sin sobrecostos.' },
  { titulo: 'Ejecución inmediata', texto: 'Tiempos de entrega que destacan frente a las nubes existentes.' },
  { titulo: 'Latencias bajas', texto: 'Arquitectura local en Colombia con latencias muy por debajo del estándar de otros servicios en la nube.' },
  { titulo: 'Nube accesible', texto: 'No monetizamos el uso del canal: transferencias y ancho de banda garantizados.' },
  { titulo: 'Solución a tu medida', texto: 'Evaluamos tus necesidades para diseñar una solución ajustada a tus requerimientos.' },
  { titulo: 'Migración gratuita', texto: 'Trasladamos sin costo tus sistemas, datos, aplicaciones y página web a nuestra nube.' },
  { titulo: 'Contratos flexibles', texto: 'Permanencia accesible según los requerimientos del servicio contratado.' },
  { titulo: 'Atención 24/7', texto: 'Expertos, arquitectos y DBAs en operación continua para lo que necesites.' },
];

const SECTORES = [
  'Desarrolladoras de software',
  'Agencias de marketing',
  'Tecnología de la información',
  'Proveedoras de software',
  'Telecomunicaciones',
];

const VENDORS = ['Acronis', 'Fortinet', 'Proxmox', 'VMware', 'Veeam'];

const FAQS = [
  {
    q: '¿Qué servicios de ciberseguridad ofrece LumaCloud?',
    a: 'Ofrecemos ciberprotección integral: antivirus EDR, DLP, seguridad perimetral, WAF, email security, SOC 24/7 con SIEM y threat hunting, backup empresarial, DRP y consultoría de cumplimiento ISO 27001 y Ley 1581.',
  },
  {
    q: '¿Dónde están los datacenters de LumaCloud?',
    a: 'Operamos con datacenters certificados TIER III y IV con arquitectura local en Colombia, lo que garantiza latencias bajas y cumplimiento de normativa local de protección de datos.',
  },
  {
    q: '¿La migración a la nube de LumaCloud tiene costo?',
    a: 'No. LumaCloud realiza sin costo adicional el traslado de tus sistemas, datos, aplicaciones y página web a nuestra nube.',
  },
  {
    q: '¿Qué es la solución 360 de LumaCloud?',
    a: 'Es la integración de infraestructura en la nube, ciberprotección, SOC y ciberrecuperación bajo un solo proveedor, con monitoreo continuo y un único punto de contacto para tu operación tecnológica.',
  },
];
---

<BaseLayout {title} {description}>
  <!-- ======== 01 · HERO ======== -->
  <section class="bg-blueprint bg-hero-mesh relative overflow-hidden">
    <!-- línea de estado técnica -->
    <div class="border-b border-frost-200/80">
      <div class="mono-label mx-auto flex max-w-7xl items-center justify-between px-4 py-2.5 text-ink-mute sm:px-6">
        <span class="flex items-center gap-2">
          <span class="blink-dot inline-block h-1.5 w-1.5 rounded-full bg-mid-500"></span>
          SOC://ACTIVO — MONITOREO 24/7
        </span>
        <span class="hidden sm:inline">BOG 4.6972°N 74.0455°W</span>
      </div>
    </div>

    <div class="mx-auto grid max-w-7xl items-end gap-10 px-4 pb-16 pt-12 sm:px-6 lg:grid-cols-[1.25fr_1fr] lg:pb-24 lg:pt-20">
      <div>
        <h1 class="animate-rise font-display text-[clamp(3.5rem,10vw,8.5rem)] leading-[0.88] text-ink">
          Ciberseguridad<br />
          y nube <span class="text-brand-gradient">empresarial</span><br />
          para Colombia
        </h1>

        <div class="animate-rise mt-8 flex max-w-xl flex-col gap-6 [animation-delay:0.12s]">
          <p class="border-l-2 border-mid-500 pl-5 text-lg leading-relaxed text-ink-soft">
            Más que servicios, una solución 360: infraestructura en la nube, ciberprotección avanzada, backup y un SOC que nunca duerme.
          </p>
          <div class="flex flex-col gap-3 sm:flex-row">
            <a
              href="/contacto"
              class="group flex items-center justify-center gap-3 rounded-xl bg-mid-500 px-7 py-4 text-base font-semibold text-white shadow-[0_8px_30px_rgb(0_115_255/0.35)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-mid-600"
            >
              Solicita tu diagnóstico gratuito
              <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M2 8h11M9 3l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
            <a
              href="#servicios"
              class="link-tech flex items-center justify-center px-4 py-4 text-base font-semibold text-cold-600"
            >
              Ver servicios ↓
            </a>
          </div>
        </div>
      </div>

      <div class="animate-wipe relative [animation-delay:0.2s]">
        <BrandImage
          src="/images/heros/home-datacenter.webp"
          alt="Datacenter de LumaCloud con racks de servidores"
          width={908}
          height={605}
          duotone
          priority
        />
        <!-- ficha técnica flotante -->
        <div class="corner-ticks absolute -bottom-5 left-4 rounded-xl border border-frost-300 bg-white/95 px-5 py-3.5 shadow-card-hover backdrop-blur">
          <div class="mono-label text-ink-mute">Datacenters</div>
          <div class="mono-data mt-1 text-xl font-medium text-cold-600">TIER III/IV <span class="text-sky-600">●</span></div>
        </div>
        <div class="mono-label absolute -top-3 right-4 rounded-md border border-frost-300 bg-white/95 px-3 py-1.5 text-ink-mute backdrop-blur">
          IMG/01 — INFRAESTRUCTURA LOCAL
        </div>
      </div>
    </div>

    <!-- métricas técnicas del hero -->
    <div class="border-t border-frost-200/80">
      <div class="mx-auto grid max-w-7xl grid-cols-2 divide-x divide-frost-200/80 px-4 sm:px-6 md:grid-cols-4">
        {
          [
            ['24/7', 'Monitoreo SOC continuo'],
            ['TIER IV', 'Certificación datacenter'],
            ['$0', 'Costo de migración'],
            ['CSIRT', 'Respuesta a incidentes'],
          ].map(([dato, label]) => (
            <div class="px-4 py-5 first:pl-0 sm:px-6">
              <p class="mono-data text-2xl font-medium text-cold-600 sm:text-3xl">{dato}</p>
              <p class="mono-label mt-1 text-ink-mute">{label}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ======== VENDORS · marquee ======== -->
  <section class="overflow-hidden border-b border-frost-200 bg-white py-6" aria-label="Tecnologías aliadas">
    <div class="flex w-max animate-marquee items-center gap-16 pr-16">
      {
        [...Array(2)].map(() => (
          <div class="flex items-center gap-16" aria-hidden="true">
            {VENDORS.map((v) => (
              <span class="flex items-center gap-16">
                <span class="font-display text-3xl tracking-wider text-ink-mute/60 transition-colors hover:text-cold-600">{v}</span>
                <span class="mono-data text-xs text-frost-300">+</span>
              </span>
            ))}
          </div>
        ))
      }
    </div>
  </section>

  <!-- ======== 02 · SERVICIOS ======== -->
  <section id="servicios" class="mx-auto max-w-7xl scroll-mt-24 px-4 py-24 sm:px-6">
    <SectionHeader
      num="02"
      eyebrow="Servicios"
      title="Una solución 360 para tu operación"
      lead="Seis líneas de servicio que trabajan como una sola plataforma, con un único punto de contacto."
    />

    <!-- mobile: carrusel con scroll-snap · desktop: bento grid -->
    <div class="scroll-reveal -mx-4 mt-12 flex snap-x snap-mandatory gap-4 overflow-x-auto px-4 pb-4 sm:mx-0 sm:grid sm:grid-cols-2 sm:overflow-visible sm:px-0 sm:pb-0 lg:grid-cols-3">
      <!-- celda grande: ciberseguridad -->
      <a href="/ciberseguridad" class="card-brand group relative min-w-[85%] snap-center overflow-hidden sm:col-span-2 sm:row-span-2 sm:min-w-0">
        <div class="img-duotone h-64 sm:h-full sm:min-h-[420px]">
          <img
            src="/images/heros/ciberseguridad-candado.webp"
            alt="Ciberseguridad empresarial: candado sobre circuito digital"
            width={1280}
            height={800}
            loading="lazy"
            class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]"
          />
        </div>
        <div class="absolute inset-0 bg-gradient-to-t from-ink/95 via-ink/35 to-transparent"></div>
        <div class="absolute inset-x-0 bottom-0 p-8">
          <p class="mono-label text-sky-500">01/ SERVICIO PRINCIPAL</p>
          <p class="font-display mt-2 text-4xl text-white sm:text-5xl">Ciberseguridad</p>
          <p class="mt-3 max-w-md text-sm leading-relaxed text-white/75">
            Ciberprotección integral con Acronis: antivirus EDR, DLP, seguridad perimetral, WAF y email security para detener amenazas antes
            de que entren.
          </p>
          <span class="link-tech mt-5 inline-flex items-center gap-2 text-sm font-semibold text-sky-500">
            Conocer el servicio
            <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M2 8h11M9 3l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </div>
      </a>

      {
        SERVICES.filter((s) => s.href !== '/ciberseguridad').map((s, i) => (
          <a href={s.href} class="card-brand group flex min-w-[75%] snap-center flex-col p-7 sm:min-w-0">
            <div class="flex items-start justify-between">
              <span class="mono-data text-sm text-mid-500">{String(i + 2).padStart(2, '0')}/</span>
              <svg
                class="h-4 w-4 -translate-x-1 translate-y-1 text-frost-300 opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:translate-y-0 group-hover:text-mid-500 group-hover:opacity-100"
                viewBox="0 0 16 16"
                fill="none"
                aria-hidden="true"
              >
                <path d="M3 13 13 3M6 3h7v7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <h3 class="mt-10 text-lg font-bold tracking-tight text-ink transition-colors group-hover:text-mid-600">{s.label}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-ink-mute">{s.desc}</p>
          </a>
        ))
      }
    </div>
  </section>

  <!-- ======== 03 · SOLUCIÓN 360 (diagrama) ======== -->
  <section class="bg-blueprint border-y border-frost-200 bg-frost-50 py-24">
    <div class="mx-auto grid max-w-7xl items-center gap-14 px-4 sm:px-6 lg:grid-cols-2">
      <div>
        <SectionHeader
          num="03"
          eyebrow="Arquitectura"
          title="Capas que se defienden entre sí"
        />
        <div class="mt-8 space-y-4 text-base leading-relaxed text-ink-soft lg:pl-[13rem]">
          <p>
            Cada capa cubre a la anterior: si una amenaza cruza la ciberprotección, el SOC la detecta; si algo falla, el backup y el DRP
            devuelven la operación. Todo sobre infraestructura local con datacenters TIER III y IV.
          </p>
          <p>
            Un solo proveedor, una sola consola, un solo responsable — en lugar de cinco contratos que no se hablan entre sí.
          </p>
          <a href="/contacto" class="link-tech inline-flex items-center gap-2 pt-2 font-semibold text-mid-600">
            Diseña tu arquitectura con nosotros
            <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M2 8h11M9 3l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>
      </div>
      <div class="scroll-reveal corner-ticks rounded-2xl border border-frost-300 bg-white p-6 sm:p-10">
        <DiagramStack />
      </div>
    </div>
  </section>

  <!-- ======== 04 · POR QUÉ ELEGIRNOS ======== -->
  <section class="mx-auto max-w-7xl px-4 py-24 sm:px-6">
    <div class="grid items-start gap-14 lg:grid-cols-[1fr_1.5fr]">
      <div class="lg:sticky lg:top-28">
        <SectionHeader num="04" eyebrow="Diferenciales" title="La decisión correcta para tu negocio" class="lg:!grid-cols-1 lg:!gap-2" />
        <p class="mt-6 max-w-md text-base leading-relaxed text-ink-soft">
          Nube diseñada para impulsar tu negocio con velocidad, seguridad y estabilidad — sin costos ocultos ni sorpresas.
        </p>
        <a
          href="/quienes-somos"
          class="link-tech mt-8 inline-flex items-center gap-2 font-semibold text-cold-600"
        >
          Conócenos
          <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M2 8h11M9 3l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>

      <!-- lista editorial con divisores, no grid de cards -->
      <div class="scroll-reveal divide-y divide-frost-200 border-y border-frost-200">
        {
          DIFERENCIALES.map((d, i) => (
            <div class="group grid gap-2 py-6 transition-colors duration-300 hover:bg-frost-50 sm:grid-cols-[4rem_14rem_1fr] sm:gap-6 sm:px-4">
              <span class="mono-data text-sm text-mid-500">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="font-bold tracking-tight text-ink">{d.titulo}</h3>
              <p class="text-sm leading-relaxed text-ink-mute">{d.texto}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ======== SECTORES + RADAR ======== -->
  <section class="border-y border-frost-200 py-24">
    <div class="mx-auto grid max-w-7xl items-center gap-14 px-4 sm:px-6 lg:grid-cols-2">
      <div class="scroll-reveal corner-ticks order-2 mx-auto w-full max-w-md lg:order-1">
        <DiagramRadar />
      </div>
      <div class="order-1 lg:order-2">
        <SectionHeader num="05" eyebrow="Sectores" title="Conocemos tu industria" class="lg:!grid-cols-1 lg:!gap-2" />
        <p class="mt-6 max-w-lg text-base leading-relaxed text-ink-soft">
          Trabajamos con empresas que dependen de su tecnología para operar y crecer. Entendemos los retos de seguridad, disponibilidad y
          cumplimiento de cada vertical.
        </p>
        <ul class="mt-8 divide-y divide-frost-200 border-y border-frost-200">
          {
            SECTORES.map((s, i) => (
              <li class="flex items-center gap-4 py-3.5">
                <span class="mono-data text-xs text-mid-500">{String(i + 1).padStart(2, '0')}</span>
                <span class="font-medium tracking-tight text-ink">{s}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <Testimonios num="06" />
  <FAQSection faqs={FAQS} num="07" />
  <CTASection />
</BaseLayout>
