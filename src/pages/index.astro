---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BrandImage from '@/components/BrandImage.astro';
import Testimonios from '@/components/Testimonios.astro';
import CTASection from '@/components/CTASection.astro';
import FAQSection from '@/components/FAQSection.astro';
import StatCallout from '@/components/StatCallout.astro';
import { SERVICES } from '@/lib/nav';

const title = 'Ciberseguridad y Nube Empresarial en Colombia | LumaCloud';
const description =
  'Soluciones de ciberseguridad administrada, backup, cloud privado y SOC 24/7 para empresas en Colombia. Datacenters TIER III y IV, migración gratuita y soporte permanente.';

const DIFERENCIALES = [
  { titulo: 'Sin sorpresas en la factura', texto: 'Precios estables y escalabilidad lineal de recursos: más hardware, procesadores o almacenamiento sin sobrecostos.' },
  { titulo: 'Ejecución inmediata', texto: 'Tiempos de entrega que destacan frente a las nubes existentes.' },
  { titulo: 'Latencias bajas', texto: 'Arquitectura local en Colombia con latencias muy por debajo del estándar de otros servicios en la nube.' },
  { titulo: 'Nube accesible', texto: 'No monetizamos el uso del canal: transferencias y ancho de banda garantizados.' },
  { titulo: 'Solución a tu medida', texto: 'Evaluamos tus necesidades para diseñar una solución ajustada a tus requerimientos.' },
  { titulo: 'Migración gratuita', texto: 'Trasladamos sin costo tus sistemas, datos, aplicaciones y página web a nuestra nube.' },
  { titulo: 'Contratos flexibles', texto: 'Permanencia accesible según los requerimientos del servicio contratado.' },
  { titulo: 'Atención 24/7', texto: 'Expertos, arquitectos y DBAs en operación continua para lo que necesites.' },
];

const SECTORES = [
  'Desarrolladoras de software',
  'Agencias de marketing',
  'Tecnología de la información',
  'Proveedoras de software',
  'Telecomunicaciones',
];

const FAQS = [
  {
    q: '¿Qué servicios de ciberseguridad ofrece LumaCloud?',
    a: 'Ofrecemos ciberprotección integral: antivirus EDR, DLP, seguridad perimetral, WAF, email security, SOC 24/7 con SIEM y threat hunting, backup empresarial, DRP y consultoría de cumplimiento ISO 27001 y Ley 1581.',
  },
  {
    q: '¿Dónde están los datacenters de LumaCloud?',
    a: 'Operamos con datacenters certificados TIER III y IV con arquitectura local en Colombia, lo que garantiza latencias bajas y cumplimiento de normativa local de protección de datos.',
  },
  {
    q: '¿La migración a la nube de LumaCloud tiene costo?',
    a: 'No. LumaCloud realiza sin costo adicional el traslado de tus sistemas, datos, aplicaciones y página web a nuestra nube.',
  },
  {
    q: '¿Qué es la solución 360 de LumaCloud?',
    a: 'Es la integración de infraestructura en la nube, ciberprotección, SOC y ciberrecuperación bajo un solo proveedor, con monitoreo continuo y un único punto de contacto para tu operación tecnológica.',
  },
];
---

<BaseLayout {title} {description} schemas={[]}>
  <!-- ======== HERO ======== -->
  <section class="bg-blueprint bg-hero-mesh relative overflow-hidden">
    <div class="mx-auto grid max-w-7xl items-center gap-12 px-4 pb-20 pt-16 sm:px-6 lg:grid-cols-[1.1fr_1fr] lg:pb-28 lg:pt-24">
      <div class="animate-rise">
        <p class="inline-flex items-center gap-2 rounded-full border border-mid-200 bg-white/70 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.15em] text-cold-600 backdrop-blur">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-sky-500 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-mid-500"></span>
          </span>
          SOC monitoreando 24/7
        </p>

        <h1 class="font-display mt-6 text-6xl leading-[0.95] text-ink sm:text-7xl lg:text-8xl">
          Ciberseguridad y nube <span class="text-brand-gradient">empresarial</span> para Colombia
        </h1>

        <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-soft">
          Más que servicios, una solución 360: infraestructura en la nube, ciberprotección avanzada, backup y un SOC que nunca duerme.
          Con datacenters TIER III y IV en arquitectura local.
        </p>

        <div class="mt-9 flex flex-col gap-4 sm:flex-row">
          <a
            href="/contacto"
            class="rounded-xl bg-mid-500 px-8 py-4 text-center text-base font-semibold text-white shadow-[0_8px_30px_rgb(0_115_255/0.35)] transition-all hover:-translate-y-0.5 hover:bg-mid-600"
          >
            Solicita tu diagnóstico gratuito
          </a>
          <a
            href="#servicios"
            class="rounded-xl border border-frost-300 bg-white/70 px-8 py-4 text-center text-base font-semibold text-cold-600 backdrop-blur transition-colors hover:border-mid-400 hover:text-mid-600"
          >
            Ver servicios
          </a>
        </div>

        <ul class="mt-10 flex flex-wrap gap-x-8 gap-y-3 text-sm font-medium text-ink-mute">
          <li class="flex items-center gap-2">
            <span class="h-1.5 w-1.5 rounded-full bg-sky-500"></span> Datacenters TIER III y IV
          </li>
          <li class="flex items-center gap-2">
            <span class="h-1.5 w-1.5 rounded-full bg-sky-500"></span> CSIRT operativo
          </li>
          <li class="flex items-center gap-2">
            <span class="h-1.5 w-1.5 rounded-full bg-sky-500"></span> Migración gratuita
          </li>
        </ul>
      </div>

      <div class="animate-rise relative [animation-delay:0.2s]">
        <div class="parallax-hero">
          <BrandImage
            src="/images/heros/home-datacenter.webp"
            alt="Datacenter de LumaCloud con racks de servidores"
            width={908}
            height={605}
            overlay
            priority
          />
        </div>
        <!-- chips flotantes: entrada escalonada (rise) + flotación continua sutil, una vez asentados -->
        <div class="animate-rise-float absolute -bottom-6 -left-4 rounded-2xl border border-frost-200 bg-white/95 px-5 py-4 shadow-card-hover backdrop-blur [animation-delay:0.35s,1.05s] sm:-left-8">
          <p class="font-display text-3xl leading-none text-mid-500">24/7</p>
          <p class="mt-1 text-xs font-medium text-ink-mute">Monitoreo SOC continuo</p>
        </div>
        <div class="animate-rise-float absolute -right-3 -top-5 rounded-2xl border border-frost-200 bg-white/95 px-5 py-4 shadow-card-hover backdrop-blur [animation-delay:0.5s,1.2s] sm:-right-6">
          <p class="font-display text-3xl leading-none text-cold-600">TIER IV</p>
          <p class="mt-1 text-xs font-medium text-ink-mute">Datacenters certificados</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ======== VENDORS / CONFIANZA (marquee) ======== -->
  <section class="border-y border-frost-200 bg-white py-8">
    <p class="text-center text-xs font-semibold uppercase tracking-[0.25em] text-ink-mute">Tecnología de clase mundial</p>
    <div class="relative mt-5 overflow-hidden [mask-image:linear-gradient(90deg,transparent,black_10%,black_90%,transparent)]">
      <div class="animate-marquee flex w-max items-center gap-16">
        {/* copia real, accesible a lectores de pantalla */}
        <div class="flex items-center gap-16">
          {['Acronis', 'Fortinet', 'Proxmox', 'VMware', 'Veeam'].map((v) => (
            <span class="font-display text-2xl tracking-wider text-ink-mute/70 transition-colors hover:text-cold-600">{v}</span>
          ))}
        </div>
        {/* copia duplicada decorativa, solo para el loop visual continuo */}
        <div class="flex items-center gap-16" aria-hidden="true">
          {['Acronis', 'Fortinet', 'Proxmox', 'VMware', 'Veeam'].map((v) => (
            <span class="font-display text-2xl tracking-wider text-ink-mute/70 transition-colors hover:text-cold-600">{v}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ======== SERVICIOS (bento) ======== -->
  <section id="servicios" class="mx-auto max-w-7xl scroll-mt-24 px-4 py-24 sm:px-6">
    <p class="text-center text-sm font-semibold uppercase tracking-[0.2em] text-mid-500">Nuestros servicios</p>
    <h2 class="font-display mt-3 text-center text-4xl text-cold-600 sm:text-6xl">Una solución 360 para tu operación</h2>
    <div class="mx-auto mt-3 w-16 brand-rule"></div>

    <div class="stagger mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      <!-- celda grande: ciberseguridad -->
      <a href="/ciberseguridad" class="card-brand scroll-reveal group relative overflow-hidden sm:col-span-2 sm:row-span-2">
        <img
          src="/images/heros/ciberseguridad-candado.webp"
          alt="Ciberseguridad empresarial: candado sobre circuito digital"
          width={1280}
          height={800}
          loading="lazy"
          class="h-64 w-full object-cover transition-transform duration-500 group-hover:scale-105 sm:h-full sm:min-h-[420px]"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-ink/90 via-ink/30 to-transparent"></div>
        <div class="absolute inset-x-0 bottom-0 p-8">
          <p class="font-display text-4xl text-white">Ciberseguridad</p>
          <p class="mt-2 max-w-md text-sm leading-relaxed text-white/75">
            Ciberprotección integral con Acronis: antivirus EDR, DLP, seguridad perimetral, WAF y email security para detener amenazas antes de que entren.
          </p>
          <span class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-sky-500">
            Conocer el servicio
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M2 8h11M9 3l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </div>
      </a>

      {
        SERVICES.filter((s) => s.href !== '/ciberseguridad').map((s) => (
          <a href={s.href} class="card-brand scroll-reveal group flex flex-col p-7">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br from-cold-600 to-mid-500 text-white shadow-[0_4px_14px_rgb(0_115_255/0.3)]">
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M10 2 3 5.5v5c0 4 3 6.5 7 7.5 4-1 7-3.5 7-7.5v-5L10 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
              </svg>
            </div>
            <h3 class="mt-5 text-lg font-bold text-ink group-hover:text-mid-600">{s.label}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-ink-mute">{s.desc}</p>
            <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-mid-500">
              Ver más
              <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M2 8h11M9 3l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- ======== POR QUÉ ELEGIRNOS ======== -->
  <section class="bg-blueprint relative bg-frost-50 py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="grid items-start gap-14 lg:grid-cols-[1fr_1.4fr]">
        <div class="lg:sticky lg:top-28">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-mid-500">Por qué elegirnos</p>
          <h2 class="font-display mt-3 text-4xl text-cold-600 sm:text-6xl">La decisión correcta para tu negocio</h2>
          <div class="mt-3 w-16 brand-rule"></div>
          <p class="mt-6 max-w-md text-base leading-relaxed text-ink-soft">
            Nube diseñada para impulsar tu negocio con velocidad, seguridad y estabilidad — sin costos ocultos ni sorpresas.
          </p>
          <a
            href="/quienes-somos"
            class="mt-8 inline-flex items-center gap-2 rounded-xl border border-frost-300 bg-white px-6 py-3 text-sm font-semibold text-cold-600 transition-colors hover:border-mid-400 hover:text-mid-600"
          >
            Conócenos
            <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M2 8h11M9 3l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>

        <div class="stagger grid gap-4 sm:grid-cols-2">
          {
            DIFERENCIALES.map((d, i) => (
              <div class="card-brand scroll-reveal p-6">
                <p class="font-display text-xl text-sky-600">{String(i + 1).padStart(2, '0')}</p>
                <h3 class="mt-2 font-bold text-ink">{d.titulo}</h3>
                <p class="mt-1.5 text-sm leading-relaxed text-ink-mute">{d.texto}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ======== SECTORES ======== -->
  <section class="mx-auto max-w-7xl px-4 py-24 sm:px-6">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-mid-500">Sectores</p>
        <h2 class="font-display mt-3 text-4xl text-cold-600 sm:text-6xl">Conocemos tu industria</h2>
        <div class="mt-3 w-16 brand-rule"></div>
        <p class="mt-6 max-w-lg text-base leading-relaxed text-ink-soft">
          Trabajamos con empresas que dependen de su tecnología para operar y crecer. Entendemos los retos de seguridad, disponibilidad y
          cumplimiento de cada vertical.
        </p>
        <ul class="mt-8 space-y-3">
          {
            SECTORES.map((s) => (
              <li class="flex items-center gap-3 text-base font-medium text-ink">
                <span class="flex h-6 w-6 items-center justify-center rounded-full bg-gradient-to-br from-mid-500 to-sky-500 text-white">
                  <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                    <path d="M2 6.5 4.5 9 10 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
                {s}
              </li>
            ))
          }
        </ul>
      </div>
      <BrandImage
        src="/images/nosotros/equipo-1.webp"
        alt="Equipo de LumaCloud revisando infraestructura en datacenter"
        width={1000}
        height={668}
        overlay
        class="scroll-reveal"
      />
    </div>
  </section>

  <Testimonios />

  <!-- ======== ESTADÍSTICA CITADA ======== -->
  <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <StatCallout
      stat="79,8%"
      label="de los incidentes de ciberseguridad gestionados por el Estado colombiano en 2024-2025 fueron fraude: phishing y compromiso de cuentas de correo."
      source="MinTIC / ColCERT — Informe de Tendencias de Amenazas Cibernéticas 2025"
      sourceUrl="https://www.mintic.gov.co/portal/inicio/Sala-de-prensa/Noticias/433511:Colombia-fortalece-su-soberania-digital-durante-2025-logro-reducir-en-un-48-los-incidentes-ciberneticos"
      class="scroll-reveal"
    />
  </section>

  <FAQSection faqs={FAQS} />
  <CTASection />
</BaseLayout>
