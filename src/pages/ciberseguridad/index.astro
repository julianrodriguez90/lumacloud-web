---
import Layout from '@/layouts/Layout.astro';
import { ctaLink } from '@/lib/appLinks';
const cta = ctaLink('ciberseguridad', 'triager');
---
<Layout
  title="Ciberseguridad Empresarial en Colombia | LumaCloud"
  description="Soluciones de ciberseguridad administrada para empresas en Colombia. Protección 24/7, respuesta a incidentes y cumplimiento normativo."
  silo="ciberseguridad"
>
  <section class="bg-brand-500 text-white py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl font-bold mb-4">Ciberseguridad empresarial en Colombia</h1>
      <p class="text-lg text-blue-100 mb-8">Protección integral contra amenazas cibernéticas. Monitoreo 24/7, respuesta a incidentes y asesoría en cumplimiento normativo para empresas colombianas.</p>
      <a href={cta} class="bg-white text-brand-500 px-8 py-3 rounded-lg font-semibold hover:bg-blue-50 transition">
        Solicita diagnóstico gratuito →
      </a>
    </div>
  </section>

  <!-- Herramienta IA: Triager de madurez -->
  <section class="max-w-3xl mx-auto px-4 py-16">
    <div class="bg-blue-50 border border-brand-100 rounded-2xl p-8">
      <h2 class="text-2xl font-bold mb-2">¿Qué tan madura es tu ciberseguridad?</h2>
      <p class="text-gray-600 mb-6">Responde 5 preguntas y recibe un diagnóstico personalizado con recomendaciones concretas.</p>
      <div id="triager" class="space-y-4">
        <p class="text-sm text-gray-500 italic">Herramienta interactiva — cargando...</p>
      </div>
      <a href={cta} class="mt-6 inline-block bg-brand-500 text-white px-6 py-3 rounded-lg font-semibold hover:bg-brand-600 transition">
        Hablar con un experto →
      </a>
    </div>
  </section>
</Layout>
