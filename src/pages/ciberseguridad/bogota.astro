---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BrandImage from '@/components/BrandImage.astro';
import CTASection from '@/components/CTASection.astro';
import FAQSection from '@/components/FAQSection.astro';
import { SITE } from '@/lib/site';

const title = 'Empresa de Ciberseguridad en Bogotá | LumaCloud';
const description =
  'Empresa de ciberseguridad en Bogotá con sede propia y SOC 24/7: protección administrada, hacking ético y respuesta a incidentes para tu negocio.';

const SERVICIOS = [
  {
    nombre: 'Ciberseguridad administrada',
    texto:
      'Antivirus EDR, DLP, seguridad perimetral, WAF y email security gestionados por nuestro equipo desde Bogotá, en una sola plataforma.',
  },
  {
    nombre: 'Hacking ético y auditoría',
    texto:
      'Evaluamos tus defensas simulando ataques reales y te entregamos un plan de remediación priorizado, con acompañamiento en la ejecución.',
  },
  {
    nombre: 'SOC 24/7',
    texto:
      'Monitoreo continuo de tu infraestructura con SIEM, threat hunting y respuesta a incidentes, todos los días del año.',
  },
  {
    nombre: 'Hardening y consultoría',
    texto:
      'Reducimos la superficie de ataque de tus sistemas y te asesoramos en la estrategia de seguridad que tu operación necesita.',
  },
  {
    nombre: 'Análisis forense',
    texto:
      'Ante un incidente, reunimos pruebas digitales en un repositorio central seguro para investigar a fondo y cerrar la brecha.',
  },
  {
    nombre: 'Protección de datos (DLP)',
    texto:
      'Evita fugas de información confidencial en más de 70 canales, con directivas ajustadas automáticamente a tu operación.',
  },
];

const VENTAJAS = [
  'Sede propia en Bogotá: nos reunimos contigo en persona cuando lo necesites',
  'Equipo local que entiende el contexto normativo y empresarial colombiano',
  'SOC con monitoreo continuo y respuesta a incidentes 24/7',
  'Un solo aliado para ciberseguridad, backup y nube empresarial',
];

const FAQS = [
  {
    q: '¿Dónde está ubicada LumaCloud en Bogotá?',
    a: `Nuestra sede está en ${SITE.address.street}, Bogotá D.C. Desde allí opera nuestro equipo de ciberseguridad, y podemos coordinar reuniones presenciales con tu empresa cuando el proyecto lo requiera.`,
  },
  {
    q: '¿Puedo tener una reunión presencial con el equipo?',
    a: 'Sí. Al estar en Bogotá, podemos visitarte en tus oficinas o recibirte en nuestra sede para levantar requerimientos, presentar resultados de auditoría o acompañar comités de seguridad. La operación diaria del servicio se gestiona de forma remota y continua.',
  },
  {
    q: '¿Qué servicios de ciberseguridad ofrecen a empresas bogotanas?',
    a: 'Ciberseguridad administrada (EDR, DLP, seguridad perimetral, WAF, email security), hacking ético y auditoría de seguridad, hardening, análisis forense y monitoreo continuo desde nuestro SOC 24/7.',
  },
  {
    q: '¿Trabajan con empresas de cualquier sector?',
    a: 'Sí. Atendemos empresas de distintos sectores en Bogotá y su sabana. Adaptamos el alcance de cada servicio al tamaño, la regulación y el nivel de riesgo de tu operación.',
  },
  {
    q: '¿Y si mi empresa tiene sedes fuera de Bogotá?',
    a: 'No hay problema. Nuestros servicios son administrados y remotos, así que protegemos todas tus sedes en Colombia desde la misma plataforma, con el mismo equipo y el mismo SOC.',
  },
];

const serviceSchema = {
  '@type': 'Service',
  name: 'Ciberseguridad para empresas en Bogotá',
  serviceType: 'Ciberseguridad administrada',
  provider: { '@id': `${SITE.url}/#organization` },
  areaServed: 'Bogotá',
  description,
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Servicios de ciberseguridad en Bogotá',
    itemListElement: SERVICIOS.map((s) => ({
      '@type': 'Offer',
      itemOffered: { '@type': 'Service', name: s.nombre },
    })),
  },
};
---

<BaseLayout
  {title}
  {description}
  breadcrumbs={[
    { name: 'Inicio', href: '/' },
    { name: 'Ciberseguridad', href: '/ciberseguridad' },
    { name: 'Bogotá', href: '/ciberseguridad/bogota' },
  ]}
  schemas={[serviceSchema]}
>
  <!-- HERO -->
  <section class="bg-blueprint bg-hero-mesh relative overflow-hidden border-b border-frost-200">
    <div class="mx-auto grid max-w-7xl items-center gap-12 px-4 pb-16 pt-14 sm:px-6 lg:grid-cols-[1.15fr_1fr] lg:pb-24 lg:pt-20">
      <div class="animate-rise">
        <nav class="text-sm text-ink-mute" aria-label="Miga de pan">
          <a href="/" class="hover:text-mid-600">Inicio</a>
          <span class="mx-2">/</span>
          <a href="/ciberseguridad" class="hover:text-mid-600">Ciberseguridad</a>
          <span class="mx-2">/</span>
          <span class="font-medium text-cold-600">Bogotá</span>
        </nav>
        <h1 class="font-display mt-5 text-5xl leading-[0.95] text-ink sm:text-6xl lg:text-7xl">
          Empresa de <span class="text-brand-gradient">ciberseguridad</span> en Bogotá
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-soft">
          Somos una empresa colombiana con sede en Bogotá. Protegemos tu negocio con ciberseguridad administrada, hacking ético y un
          SOC 24/7 — y cuando lo necesites, nos sentamos contigo en la misma mesa.
        </p>
        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a
            href="/contacto"
            class="rounded-xl bg-mid-500 px-8 py-4 text-center font-semibold text-white shadow-[0_8px_30px_rgb(0_115_255/0.35)] transition-all hover:-translate-y-0.5 hover:bg-mid-600"
          >
            Solicita tu diagnóstico gratuito
          </a>
          <a
            href="/soc"
            class="rounded-xl border border-frost-300 bg-white/70 px-8 py-4 text-center font-semibold text-cold-600 backdrop-blur transition-colors hover:border-mid-400 hover:text-mid-600"
          >
            Conoce nuestro SOC 24/7
          </a>
        </div>
      </div>
      <BrandImage
        src="/images/nosotros/equipo-2.webp"
        alt="Equipo de ciberseguridad de LumaCloud en su sede de Bogotá"
        width={1000}
        height={668}
        overlay
        priority
        class="animate-rise [animation-delay:0.15s]"
      />
    </div>
  </section>

  <!-- CERCANÍA / SEDE -->
  <section class="bg-blueprint bg-frost-50 py-20">
    <div class="mx-auto grid max-w-7xl items-center gap-12 px-4 sm:px-6 lg:grid-cols-2">
      <div class="scroll-reveal">
        <h2 class="font-display text-4xl text-cold-600 sm:text-5xl">Seguridad con un aliado que está cerca</h2>
        <div class="mt-3 w-16 brand-rule"></div>
        <div class="mt-6 space-y-4 text-base leading-relaxed text-ink-soft">
          <p>
            Bogotá concentra buena parte del tejido empresarial del país: sedes corporativas, entidades financieras, empresas de
            servicios y un ecosistema creciente de compañías digitales. Todas comparten el mismo reto — proteger su información y su
            operación frente a amenazas cada vez más sofisticadas.
          </p>
          <p>
            Nuestra ventaja es la cercanía. Operamos desde nuestra sede en {SITE.address.street}, Bogotá D.C., así que además del
            servicio administrado remoto puedes contar con reuniones presenciales: levantamiento de requerimientos en tus oficinas,
            presentación de resultados de auditoría ante tu junta o acompañamiento en comités de seguridad.
          </p>
          <p>
            Y la operación nunca se detiene: la vigilancia diaria de tu infraestructura corre por cuenta de nuestro
            <a href="/soc" class="font-semibold text-mid-500 hover:text-mid-600">SOC 24/7</a>, con toda nuestra oferta de
            <a href="/ciberseguridad" class="font-semibold text-mid-500 hover:text-mid-600">ciberseguridad administrada</a> detrás.
          </p>
        </div>
        <ul class="mt-8 space-y-3">
          {
            VENTAJAS.map((b) => (
              <li class="flex items-start gap-3 text-ink">
                <span class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-mid-500 to-sky-500 text-white">
                  <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                    <path d="M2 6.5 4.5 9 10 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
                <span class="text-[0.95rem] font-medium">{b}</span>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="space-y-6">
        <BrandImage
          src="/images/heros/soc-analista.webp"
          alt="Analista del SOC de LumaCloud monitoreando amenazas para empresas de Bogotá"
          width={1280}
          height={800}
          overlay
          class="scroll-reveal"
        />
        <div class="card-brand p-7">
          <p class="font-display text-2xl text-cold-600">Visítanos en Bogotá</p>
          <p class="mt-2 text-sm leading-relaxed text-ink-mute">
            {SITE.address.street}, Bogotá D.C. — agenda una reunión con nuestro equipo y revisemos juntos la postura de seguridad de tu
            empresa.
          </p>
          <a href="/contacto" class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-mid-500 hover:text-mid-600">
            Agenda una reunión
            <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M2 8h11M9 3l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICIOS -->
  <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6">
    <p class="text-center mono-label text-mid-500">Servicios en Bogotá</p>
    <h2 class="font-display mt-3 text-center text-4xl text-cold-600 sm:text-5xl">Todo lo que tu empresa necesita para defenderse</h2>
    <div class="mx-auto mt-3 w-16 brand-rule"></div>

    <div class="scroll-reveal mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        SERVICIOS.map((s) => (
          <div class="card-brand p-7">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br from-cold-600 to-mid-500 text-white">
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M10 2 3 5.5v5c0 4 3 6.5 7 7.5 4-1 7-3.5 7-7.5v-5L10 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                <path d="M7 10l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <h3 class="mt-5 text-lg font-bold text-ink">{s.nombre}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-mute">{s.texto}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ENLACES DE SILO -->
  <section class="mx-auto max-w-7xl px-4 pb-16 sm:px-6">
    <h2 class="font-display text-3xl text-cold-600 sm:text-4xl">Explora nuestros servicios</h2>
    <div class="mt-8 grid gap-5 sm:grid-cols-3">
      {
        [
          { href: '/ciberseguridad', label: 'Ciberseguridad administrada', desc: 'EDR, DLP, seguridad perimetral, WAF y email security en una sola plataforma.' },
          { href: '/ciberseguridad/consultoria', label: 'Consultoría en ciberseguridad', desc: 'Diagnóstico, hoja de ruta y acompañamiento experto para tu empresa.' },
          { href: '/soc', label: 'SOC 24/7', desc: 'Monitoreo continuo con SIEM, threat hunting y respuesta a incidentes.' },
        ].map((l) => (
          <a href={l.href} class="card-brand group p-7">
            <h3 class="font-bold text-ink group-hover:text-mid-600">{l.label}</h3>
            <p class="mt-2 text-sm text-ink-mute">{l.desc}</p>
            <span class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-mid-500">
              Ver más
              <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M2 8h11M9 3l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <FAQSection faqs={FAQS} />
  <CTASection
    title="Hablemos en Bogotá"
    text="Agenda un diagnóstico gratuito de ciberseguridad: evaluamos la exposición de tu empresa y, si lo prefieres, lo revisamos juntos en una reunión presencial."
    ctaLabel="Solicita tu diagnóstico gratuito"
  />
</BaseLayout>
