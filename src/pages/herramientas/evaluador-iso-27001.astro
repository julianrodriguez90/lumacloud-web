---
import Layout from '@/layouts/Layout.astro';
---
<Layout
  title="Evaluador de brecha ISO 27001 gratis | LumaCloud"
  description="Evalúa el cumplimiento de tu empresa con la norma ISO 27001:2022 en solo 2 minutos. Recibe una hoja de ruta de remediación."
  silo="cumplimiento"
>
  <section class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold mb-4">Evaluador de brecha ISO 27001</h1>
    <p class="text-gray-600 mb-8">
      Mide el nivel de madurez de tu Sistema de Gestión de Seguridad de la Información (SGSI)
      basado en los controles clave de la norma ISO 27001:2022.
    </p>

    <div id="evaluador" class="bg-white border border-gray-200 rounded-2xl p-8 shadow-sm">
      <div id="quiz-container" class="space-y-8">
        <!-- Preguntas se insertarán aquí -->
        <div class="text-center py-12">
          <p class="text-gray-500">Cargando evaluación...</p>
        </div>
      </div>

      <div id="results-container" class="hidden space-y-6">
        <div class="bg-blue-50 p-6 rounded-xl border border-blue-100">
          <h2 class="text-2xl font-bold text-blue-900 mb-2">Tu Resultado: <span id="score-val">0</span>%</h2>
          <div class="w-full bg-blue-200 rounded-full h-4">
            <div id="score-bar" class="bg-brand-500 h-4 rounded-full" style="width: 0%"></div>
          </div>
          <p id="score-desc" class="mt-4 text-blue-800 font-medium"></p>
        </div>

        <div class="space-y-4">
          <h3 class="font-bold text-lg">Hoja de ruta recomendada:</h3>
          <ul id="recommendations" class="list-disc pl-5 space-y-2 text-gray-700"></ul>
        </div>

        <div class="pt-6 border-t border-gray-100">
          <a href="/contacto?utm_source=herramienta&utm_medium=organic&utm_campaign=cumplimiento&utm_content=evaluador-iso"
             class="block w-full bg-brand-500 text-white text-center py-3 rounded-lg font-bold hover:bg-brand-600 transition">
            Solicitar asesoría para certificación ISO 27001
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
const questions = [
  { id: 1, q: "¿Cuenta la empresa con una Política de Seguridad de la Información aprobada por la dirección?", category: "Políticas" },
  { id: 2, q: "¿Se realizan análisis de riesgos de seguridad de forma periódica?", category: "Riesgos" },
  { id: 3, q: "¿Tienen implementado un proceso formal de gestión de incidentes de seguridad?", category: "Incidentes" },
  { id: 4, q: "¿Se realiza capacitación en seguridad a todos los empleados al menos una vez al año?", category: "Personas" },
  { id: 5, q: "¿Existen controles de acceso lógico (MFA, contraseñas robustas) para sistemas críticos?", category: "Técnico" }
];

let answers = {};

function renderQuiz() {
  const container = document.getElementById('quiz-container');
  container.innerHTML = questions.map(q => `
    <div class="space-y-3">
      <p class="font-medium text-gray-900">${q.id}. ${q.q}</p>
      <div class="flex gap-4">
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="radio" name="q${q.id}" value="yes" class="w-4 h-4 text-brand-500" />
          <span class="text-sm text-gray-700">Sí</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="radio" name="q${q.id}" value="partial" class="w-4 h-4 text-brand-500" />
          <span class="text-sm text-gray-700">Parcialmente</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="radio" name="q${q.id}" value="no" class="w-4 h-4 text-brand-500" />
          <span class="text-sm text-gray-700">No</span>
        </label>
      </div>
    </div>
  `).join('') + `
    <button id="submit-eval" class="w-full bg-brand-500 text-white py-3 rounded-lg font-bold mt-8">Ver resultados</button>
  `;

  document.getElementById('submit-eval').addEventListener('click', calculateResults);
}

function calculateResults() {
  let score = 0;
  let recs = [];

  questions.forEach(q => {
    const val = document.querySelector(`input[name="q${q.id}"]:checked`)?.value;
    if (val === 'yes') score += 20;
    if (val === 'partial') score += 10;

    if (val !== 'yes') {
      if (q.id === 1) recs.push("Formalizar y comunicar la Política de Seguridad.");
      if (q.id === 2) recs.push("Realizar un inventario de activos y evaluación de riesgos.");
      if (q.id === 3) recs.push("Definir un protocolo de respuesta ante incidentes.");
      if (q.id === 4) recs.push("Implementar un plan de concientización continua.");
      if (q.id === 5) recs.push("Reforzar controles de acceso con MFA.");
    }
  });

  if (recs.length === 0) recs.push("Mantener el cumplimiento y prepararse para la auditoría de certificación.");

  document.getElementById('quiz-container').classList.add('hidden');
  document.getElementById('results-container').classList.remove('hidden');
  document.getElementById('score-val').textContent = score;
  document.getElementById('score-bar').style.width = `${score}%`;

  const desc = score < 40 ? "Crítico: Tu SGSI requiere intervención inmediata." :
               score < 80 ? "En proceso: Tienes bases, pero faltan controles clave." :
               "Excelente: Estás cerca del cumplimiento total.";
  document.getElementById('score-desc').textContent = desc;

  document.getElementById('recommendations').innerHTML = recs.map(r => `<li>${r}</li>`).join('');
}

renderQuiz();
</script>
