---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTASection from '@/components/CTASection.astro';
import FAQSection from '@/components/FAQSection.astro';
import { SITE } from '@/lib/site';

const title = 'Evaluador de Brecha ISO 27001 Gratis | LumaCloud';
const description =
  'Evalúa gratis qué tan preparada está tu empresa para ISO 27001: 10 preguntas sobre controles clave, porcentaje de preparación y brechas prioritarias en 2 minutos.';

const PREGUNTAS = [
  { id: 'politica', q: '¿Tu empresa tiene una política de seguridad de la información documentada y aprobada por la dirección?', gap: 'Sin política formal no hay SGSI: es el primer requisito del estándar y la base de todos los controles.' },
  { id: 'activos', q: '¿Mantienen un inventario actualizado de activos de información (servidores, aplicaciones, bases de datos, dispositivos)?', gap: 'No puedes proteger lo que no sabes que tienes. El inventario de activos es prerrequisito del análisis de riesgos.' },
  { id: 'accesos', q: '¿Los accesos a sistemas se otorgan por rol, se revisan periódicamente y se revocan al retirarse un colaborador?', gap: 'El control de accesos es de los dominios con más hallazgos en auditoría: cuentas huérfanas y privilegios excesivos.' },
  { id: 'cifrado', q: '¿La información sensible está cifrada en tránsito y en reposo?', gap: 'El cifrado protege los datos incluso si otros controles fallan, y es exigido también por la Ley 1581 para datos personales.' },
  { id: 'backup', q: '¿Realizan copias de seguridad periódicas y han PROBADO restaurarlas en el último año?', gap: 'Un backup sin prueba de restauración es una esperanza, no un control. ISO 27001 exige verificar la recuperabilidad.' },
  { id: 'incidentes', q: '¿Existe un procedimiento definido para reportar y gestionar incidentes de seguridad?', gap: 'Sin gestión de incidentes, cada evento se improvisa: más daño, más tiempo de recuperación y sin lecciones aprendidas.' },
  { id: 'continuidad', q: '¿Tienen un plan de continuidad del negocio o DRP documentado y probado?', gap: 'La continuidad es un dominio completo del Anexo A: el negocio debe poder operar aunque falle la tecnología.' },
  { id: 'proveedores', q: '¿Evalúan la seguridad de sus proveedores críticos (cloud, software, outsourcing) antes y durante el contrato?', gap: 'La cadena de suministro es un vector de ataque creciente: el estándar exige gestionar la seguridad en las relaciones con proveedores.' },
  { id: 'capacitacion', q: '¿El personal recibe capacitación periódica en seguridad de la información (phishing, manejo de datos)?', gap: 'El error humano sigue siendo la principal puerta de entrada: la concientización es un control obligatorio.' },
  { id: 'monitoreo', q: '¿Monitorean y registran eventos de seguridad en sus sistemas (logs centralizados, alertas)?', gap: 'Sin monitoreo no hay detección: los atacantes pueden permanecer semanas dentro de la red sin que nadie lo note.' },
];

const FAQS = [
  {
    q: '¿Qué es ISO 27001?',
    a: 'ISO/IEC 27001 es el estándar internacional para sistemas de gestión de seguridad de la información (SGSI). Define cómo una organización identifica sus riesgos y aplica controles —técnicos, organizativos y humanos— para proteger la confidencialidad, integridad y disponibilidad de su información.',
  },
  {
    q: '¿Este evaluador equivale a una auditoría ISO 27001?',
    a: 'No. Es una autoevaluación orientativa sobre 10 controles clave del Anexo A. Una auditoría formal revisa el SGSI completo con evidencias. Úsalo como termómetro inicial para saber dónde estás parado.',
  },
  {
    q: '¿LumaCloud certifica empresas en ISO 27001?',
    a: 'No emitimos certificaciones (eso lo hacen organismos acreditados), pero implementamos los controles técnicos que el estándar exige: backup verificado, cifrado, monitoreo SOC 24/7, gestión de accesos y DLP, y te acompañamos en el cierre de brechas.',
  },
  {
    q: '¿Cuánto tarda una empresa en prepararse para ISO 27001?',
    a: 'Depende del punto de partida y del alcance del SGSI. La preparación típica implica análisis de brecha, implementación de controles y un periodo de operación con evidencias antes de la auditoría de certificación.',
  },
];

const appSchema = {
  '@type': 'SoftwareApplication',
  name: 'Evaluador de brecha ISO 27001 de LumaCloud',
  url: `${SITE.url}/herramientas/evaluador-iso-27001`,
  applicationCategory: 'SecurityApplication',
  operatingSystem: 'Web',
  description,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'COP' },
  provider: { '@id': `${SITE.url}/#organization` },
};
---

<BaseLayout
  {title}
  {description}
  breadcrumbs={[
    { name: 'Inicio', href: '/' },
    { name: 'Evaluador ISO 27001', href: '/herramientas/evaluador-iso-27001' },
  ]}
  schemas={[appSchema]}
>
  <section class="bg-blueprint bg-hero-mesh relative overflow-hidden border-b border-frost-200">
    <div class="mx-auto max-w-7xl px-4 pb-12 pt-14 sm:px-6 lg:pb-16 lg:pt-20">
      <div class="animate-rise max-w-3xl">
        <nav class="text-sm text-ink-mute" aria-label="Miga de pan">
          <a href="/" class="hover:text-mid-600">Inicio</a>
          <span class="mx-2">/</span>
          <span>Herramientas</span>
          <span class="mx-2">/</span>
          <span class="font-medium text-cold-600">Evaluador ISO 27001</span>
        </nav>
        <h1 class="font-display mt-5 text-5xl leading-[0.95] text-ink sm:text-6xl lg:text-7xl">
          Evaluador de brecha <span class="text-brand-gradient">ISO 27001</span> gratuito
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-soft">
          Diez preguntas sobre los controles clave del estándar. En 2 minutos sabes tu porcentaje de preparación y cuáles son tus brechas
          prioritarias. Gratis y sin registro.
        </p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6">
    <div class="card-brand p-7 sm:p-9">
      <h2 class="font-display text-3xl text-cold-600 sm:text-4xl">Responde sobre tu empresa hoy</h2>
      <div class="mt-3 w-16 brand-rule"></div>

      <form id="form-iso" class="mt-8 space-y-5" novalidate>
        {
          PREGUNTAS.map((p, i) => (
            <fieldset class="rounded-2xl border border-frost-200 p-5">
              <legend class="px-2 text-sm font-semibold text-ink">
                {i + 1}. {p.q}
              </legend>
              <div class="mt-3 flex flex-col gap-2 sm:flex-row">
                <label class="flex min-h-11 flex-1 cursor-pointer items-center gap-2.5 rounded-lg border border-frost-300 px-4 py-2.5 text-sm text-ink-soft transition-colors has-[:checked]:border-mid-400 has-[:checked]:bg-mid-50 has-[:checked]:text-mid-700">
                  <input type="radio" name={p.id} value="1" class="h-4 w-4 shrink-0 accent-mid-500" required />
                  Sí
                </label>
                <label class="flex min-h-11 flex-1 cursor-pointer items-center gap-2.5 rounded-lg border border-frost-300 px-4 py-2.5 text-sm text-ink-soft transition-colors has-[:checked]:border-mid-400 has-[:checked]:bg-mid-50 has-[:checked]:text-mid-700">
                  <input type="radio" name={p.id} value="0" class="h-4 w-4 shrink-0 accent-mid-500" />
                  No / No estoy seguro
                </label>
              </div>
            </fieldset>
          ))
        }
        <button
          type="submit"
          class="w-full rounded-xl bg-mid-500 px-8 py-4 font-semibold text-white shadow-[0_8px_30px_rgb(0_115_255/0.35)] transition-all hover:-translate-y-0.5 hover:bg-mid-600 sm:w-auto"
        >
          Calcular mi preparación
        </button>
        <p id="iso-error" class="hidden text-sm font-medium text-red-600" role="alert">Responde todas las preguntas para calcular tu resultado.</p>
      </form>

      <!-- RESULTADO -->
      <div id="iso-resultado" class="mt-10 hidden border-t border-frost-200 pt-8" aria-live="polite">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-mid-500">Tu resultado</p>
        <div class="mt-4 flex items-end gap-4">
          <p class="font-display text-7xl leading-none text-cold-600"><span id="iso-score">0</span>%</p>
          <p id="iso-nivel" class="pb-2 text-lg font-bold text-ink"></p>
        </div>
        <div class="mt-4 h-3 overflow-hidden rounded-full bg-frost-200">
          <div id="iso-barra" class="bg-brand-gradient h-full rounded-full transition-all duration-700" style="width: 0%"></div>
        </div>
        <div id="iso-gaps" class="mt-8 space-y-3"></div>
        <div class="mt-8 rounded-2xl bg-frost-50 p-6 text-center">
          <p class="font-semibold text-ink">¿Quieres cerrar estas brechas con un plan concreto?</p>
          <p class="mt-1 text-sm text-ink-mute">Te ayudamos a implementar los controles técnicos que ISO 27001 exige.</p>
          <a
            href="/contacto"
            class="mt-4 inline-block rounded-xl bg-mid-500 px-7 py-3.5 font-semibold text-white transition-all hover:-translate-y-0.5 hover:bg-mid-600"
          >
            Agenda tu diagnóstico gratuito
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- EDUCATIVO -->
  <section class="bg-frost-50 py-16">
    <div class="prose-luma mx-auto max-w-3xl px-4 sm:px-6">
      <h2>¿Qué evalúa esta herramienta?</h2>
      <p>
        Las 10 preguntas corresponden a controles del Anexo A de ISO/IEC 27001:2022 que concentran la mayoría de los hallazgos en
        auditorías: política de seguridad, inventario de activos, control de accesos, cifrado, copias de seguridad verificadas, gestión de
        incidentes, continuidad del negocio, seguridad con proveedores, concientización del personal y monitoreo de eventos.
      </p>
      <p>
        El resultado es orientativo: un análisis de brecha formal revisa el alcance completo del SGSI con evidencias. Si tu empresa maneja
        datos personales, estos mismos controles apoyan el <a href="/cumplimiento/ley-1581">cumplimiento de la Ley 1581</a> ante la SIC.
      </p>
    </div>
  </section>

  <FAQSection faqs={FAQS} />
  <CTASection
    title="Cierra tus brechas de seguridad"
    text="Implementamos los controles técnicos de ISO 27001: backup verificado, cifrado, monitoreo SOC 24/7 y gestión de accesos."
  />
</BaseLayout>

<script define:vars={{ preguntas: PREGUNTAS }}>
  const form = document.getElementById('form-iso');
  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const errorEl = document.getElementById('iso-error');
    if ([...data.keys()].length < preguntas.length) {
      errorEl.classList.remove('hidden');
      return;
    }
    errorEl.classList.add('hidden');

    const gaps = preguntas.filter((p) => data.get(p.id) === '0');
    const score = Math.round(((preguntas.length - gaps.length) / preguntas.length) * 100);

    document.getElementById('iso-score').textContent = score;
    document.getElementById('iso-barra').style.width = score + '%';
    document.getElementById('iso-nivel').textContent =
      score >= 80 ? 'Preparación alta' : score >= 50 ? 'Preparación media' : 'Preparación inicial';

    const gapsEl = document.getElementById('iso-gaps');
    gapsEl.innerHTML = '';
    if (gaps.length === 0) {
      gapsEl.innerHTML =
        '<p class="text-ink-soft text-sm">No detectamos brechas en los controles evaluados. El siguiente paso natural es un análisis de brecha formal sobre el Anexo A completo.</p>';
    } else {
      const titulo = document.createElement('p');
      titulo.className = 'font-bold text-ink';
      titulo.textContent = `Brechas prioritarias (${gaps.length}):`;
      gapsEl.appendChild(titulo);
      for (const g of gaps) {
        const div = document.createElement('div');
        div.className = 'rounded-xl border border-frost-200 bg-white p-4';
        const q = document.createElement('p');
        q.className = 'text-sm font-semibold text-cold-600';
        q.textContent = g.q;
        const a = document.createElement('p');
        a.className = 'mt-1 text-sm text-ink-mute';
        a.textContent = g.gap;
        div.append(q, a);
        gapsEl.appendChild(div);
      }
    }
    document.getElementById('iso-resultado').classList.remove('hidden');
    document.getElementById('iso-resultado').scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
