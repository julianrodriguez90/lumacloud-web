---
import Layout from '@/layouts/Layout.astro';
---
<Layout
  title="Calculadora de Migración a la Nube | LumaCloud"
  description="Calcula el costo y la mejor estrategia para migrar tu infraestructura a la nube en Colombia. IaaS, PaaS o Cloud Privado."
  silo="cloud"
>
  <section class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold mb-4">Calculadora de Migración Cloud</h1>
    <p class="text-gray-600 mb-8">
      Descubre qué modelo de nube es ideal para tus cargas de trabajo actuales y obtén un estimado
      de inversión para tu migración.
    </p>

    <div class="bg-white border border-gray-200 rounded-2xl p-8 shadow-sm">
      <div class="space-y-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Número de servidores actuales</label>
          <input type="number" id="servers" value="5" class="w-full border border-gray-300 rounded-lg px-3 py-2" />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Tipo de aplicaciones</label>
          <select id="app-type" class="w-full border border-gray-300 rounded-lg px-3 py-2">
            <option value="legacy">Legacy (Bases de datos antiguas, ERP local)</option>
            <option value="web">Web / Aplicaciones modernas</option>
            <option value="data">Big Data / Análisis</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Prioridad principal</label>
          <div class="grid grid-cols-2 gap-3">
            <button onclick="setPriority('cost')" id="btn-cost" class="priority-btn border border-gray-300 py-2 rounded hover:border-brand-500">Ahorro de Costo</button>
            <button onclick="setPriority('security')" id="btn-security" class="priority-btn border border-brand-500 bg-brand-50 py-2 rounded text-brand-700">Seguridad/Soberanía</button>
          </div>
        </div>

        <button onclick="calculateMigration()" class="w-full bg-brand-500 text-white py-3 rounded-lg font-bold">Calcular Arquitectura</button>
      </div>

      <div id="migration-result" class="hidden mt-8 p-6 bg-blue-50 rounded-xl border border-blue-100">
        <h3 class="text-xl font-bold text-blue-900 mb-4">Recomendación de Arquitectura</h3>
        <div id="migration-content" class="text-sm text-blue-800 space-y-3"></div>
        <a href="/contacto" class="block mt-6 bg-brand-500 text-white text-center py-2 rounded font-medium">Hablar con un arquitecto cloud</a>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
let priority = 'security';

function setPriority(p) {
  priority = p;
  document.querySelectorAll('.priority-btn').forEach(b => {
    b.className = 'priority-btn border border-gray-300 py-2 rounded hover:border-brand-500';
  });
  document.getElementById('btn-' + p).className = 'priority-btn border border-brand-500 bg-brand-50 py-2 rounded text-brand-700';
}

function calculateMigration() {
  const servers = parseInt(document.getElementById('servers').value);
  const appType = document.getElementById('app-type').value;
  const resultDiv = document.getElementById('migration-result');
  const content = document.getElementById('migration-content');

  let recommendation = "";
  let model = "";

  if (priority === 'security' || appType === 'legacy') {
    model = "Cloud Privado (VMware/Nutanix)";
    recommendation = `Ideal para mantener soberanía de datos en Colombia y asegurar aplicaciones legacy sin cambios de código.`;
  } else {
    model = "Cloud Público / IaaS";
    recommendation = `Recomendamos un enfoque de 'Rehosting' hacia infraestructura escalable para optimizar costos de operación.`;
  }

  const cost = servers * 120;

  content.innerHTML = `
    <p><strong>Modelo sugerido:</strong> ${model}</p>
    <p><strong>Estrategia:</strong> ${appType === 'web' ? 'Refactor / Modernización' : 'Lift & Shift'}</p>
    <p><strong>Inversión estimada:</strong> ~$${cost.toLocaleString()} USD/mes</p>
    <p class="mt-4 italic text-xs">${recommendation}</p>
  `;

  resultDiv.classList.remove('hidden');
}
</script>
