---
import Layout from '@/layouts/Layout.astro';
---
<Layout
  title="Calculadora RTO/RPO gratuita para empresas | LumaCloud"
  description="Calcula el RTO y RPO ideal para tu empresa colombiana. Herramienta gratuita para planificar tu estrategia de backup y recuperación ante desastres."
  silo="backup"
>
  <section class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold mb-4">Calculadora RTO/RPO para empresas</h1>
    <p class="text-gray-600 mb-8">
      Ingresa los datos de tu empresa y obtén una recomendación personalizada de estrategia de backup
      con el RTO y RPO óptimos para tu operación.
    </p>
    <div id="calculadora" class="bg-gray-50 border border-gray-200 rounded-2xl p-8 space-y-6">

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Industria de tu empresa</label>
        <select id="industria" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
          <option value="financiero">Financiero / Banca</option>
          <option value="salud">Salud / Clínicas</option>
          <option value="retail">Retail / E-commerce</option>
          <option value="manufactura">Manufactura / Industrial</option>
          <option value="servicios" selected>Servicios Profesionales</option>
          <option value="educacion">Educación</option>
          <option value="gobierno">Gobierno / Público</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Volumen de datos críticos (TB)</label>
        <input id="volumen" type="number" min="0.1" max="500" step="0.1" value="2"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500" />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">¿Cuánto tiempo puede tolerar tu empresa sin sistemas? (horas)</label>
        <input id="tolerancia" type="range" min="1" max="72" value="4" class="w-full" />
        <p class="text-sm text-gray-500 mt-1">Tolerancia actual: <span id="tolerancia-val">4</span> horas</p>
      </div>

      <button id="calcular"
        class="w-full bg-brand-500 hover:bg-brand-600 text-white py-3 rounded-lg font-semibold transition">
        Calcular mi RTO/RPO →
      </button>

      <div id="resultado" class="hidden mt-4 bg-white border border-green-200 rounded-xl p-6">
        <h3 class="font-bold text-lg mb-3 text-green-700">Tu recomendación personalizada</h3>
        <div id="resultado-contenido" class="space-y-2 text-sm text-gray-700"></div>
        <a id="resultado-cta" href="#"
          class="mt-4 inline-block bg-brand-500 text-white px-6 py-2 rounded-lg text-sm font-semibold hover:bg-brand-600 transition">
          Cotizar este plan →
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
document.getElementById('tolerancia').addEventListener('input', function() {
  document.getElementById('tolerancia-val').textContent = this.value;
});

document.getElementById('calcular').addEventListener('click', function() {
  const industria = document.getElementById('industria').value;
  const volumen   = parseFloat(document.getElementById('volumen').value);
  const tolerancia= parseInt(document.getElementById('tolerancia').value);

  const recs = {
    financiero: { rto: '1 hora',  rpo: '15 min', plan: 'Backup continuo (CDP) + replicación en tiempo real', tier: 'Enterprise' },
    salud:      { rto: '2 horas', rpo: '30 min', plan: 'Backup each-15min + snapshot horario + DRP activo', tier: 'Enterprise' },
    retail:     { rto: '4 horas', rpo: '1 hora', plan: 'Backup horario + snapshot diario + failover cloud', tier: 'Business' },
    manufactura:{ rto: '8 horas', rpo: '4 horas', plan: 'Backup diario incremental + snapshot semanal', tier: 'Standard' },
    servicios:  { rto: '4 horas', rpo: '2 horas', plan: 'Backup diario + snapshot diario + retención 90 días', tier: 'Business' },
    educacion:  { rto: '12 horas', rpo: '8 horas', plan: 'Backup nocturno + retención 1 año', tier: 'Standard' },
    gobierno:   { rto: '4 horas', rpo: '1 hora', plan: 'Backup horario + cumplimiento Ley 1712 + DRP', tier: 'Government' },
  };

  const r = recs[industria] || recs['servicios'];
  const costoBase = volumen < 1 ? 150 : volumen < 5 ? 280 : volumen < 20 ? 550 : 950;
  const costo = `$${costoBase.toLocaleString('es-CO')} USD/mes aprox.`;

  document.getElementById('resultado-contenido').innerHTML = `
    <p>🎯 <strong>RTO recomendado:</strong> ${r.rto}</p>
    <p>⏱️ <strong>RPO recomendado:</strong> ${r.rpo}</p>
    <p>📦 <strong>Plan sugerido:</strong> ${r.plan}</p>
    <p>💰 <strong>Costo estimado:</strong> ${costo} (${volumen} TB · plan ${r.tier})</p>
    <p class="text-gray-400 text-xs mt-2">* Estimación referencial. El precio final depende de configuración específica.</p>
  `;

  const slug = `calculadora-rto-rpo`;
  document.getElementById('resultado-cta').href =
    `/contacto?utm_source=herramienta&utm_medium=organic&utm_campaign=backup&utm_content=${slug}&industria=${industria}&rto=${encodeURIComponent(r.rto)}`;

  document.getElementById('resultado').classList.remove('hidden');
});
</script>
