---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BrandImage from '@/components/BrandImage.astro';
import CTASection from '@/components/CTASection.astro';
import FAQSection from '@/components/FAQSection.astro';
import { SITE } from '@/lib/site';

const title = 'SOC as a Service 24/7 en Colombia | LumaCloud';
const description =
  'Centro de operaciones de seguridad gestionado 24/7: SIEM, SOAR, threat hunting y respuesta a incidentes con CSIRT para empresas en Colombia.';

const CAPACIDADES = [
  {
    nombre: 'SIEM',
    texto:
      'Correlación y análisis de eventos de seguridad en tiempo real desde todas tus fuentes. Con FortiSIEM obtenemos una vista unificada de tu operación, con monitoreo en vivo e histórico.',
  },
  {
    nombre: 'SOAR',
    texto:
      'Orquestación y automatización de la respuesta: aislar un equipo, bloquear una IP en el firewall o eliminar un correo malicioso ocurre en segundos, no en horas, con playbooks personalizados.',
  },
  {
    nombre: 'Threat Hunting',
    texto:
      'Caza proactiva de amenazas: nuestros analistas buscan indicadores de compromiso en tus logs sin esperar una alerta, para detectar ataques silenciosos antes de que generen impacto.',
  },
  {
    nombre: 'Sandbox',
    texto:
      'Análisis de archivos sospechosos en un entorno aislado y seguro para observar su comportamiento e identificar malware avanzado y amenazas zero-day que evaden las defensas tradicionales.',
  },
  {
    nombre: 'IDS — Detección de intrusiones',
    texto:
      'Detección y gestión de ataques avanzados sobre tu red: identificamos intentos de acceso, escaneos y comportamientos anómalos en tu infraestructura.',
  },
  {
    nombre: 'Gestión de vulnerabilidades',
    texto:
      'Identificamos sistemas expuestos a nuevas CVE críticas y generamos acciones concretas: parcheo, aislamiento temporal o bloqueo de puertos, antes de que alguien las explote.',
  },
];

const FAQS = [
  {
    q: '¿Qué es SOC as a Service y en qué se diferencia de tener un SOC propio?',
    a: 'Es un Centro de Operaciones de Ciberseguridad que operamos por ti: monitorea, previene, mitiga y responde a amenazas sobre tu infraestructura. Montar un SOC propio exige una gran inversión en hardware y personal especializado; con LumaCloud accedes a esa infraestructura de clase mundial por una fracción del costo.',
  },
  {
    q: 'Ya tengo antivirus y firewall, ¿no es suficiente?',
    a: 'El antivirus es un candado en la puerta; el Cyber SOC es un equipo de vigilancia permanente sobre todo el perímetro. El antivirus avisa cuando ya entraron; el SOC correlaciona eventos de todas tus fuentes con SIEM, detecta comportamientos anómalos y responde antes de que la amenaza se propague.',
  },
  {
    q: '¿Qué pasa si nos atacan un domingo a las 3:00 a. m.?',
    a: 'El monitoreo es 24/7 y no se detiene en festivos. El SOAR reacciona de forma automática para contener la amenaza, mientras los analistas de nuestro CSIRT (Equipo de Respuesta a Incidentes de Seguridad Informática) toman el control en menos de 15 minutos.',
  },
  {
    q: '¿Cuánto tarda la implementación del servicio?',
    a: 'La implementación es rápida: puede ejecutarse en unos 5 días y máximo una semana, sin interrumpir tu operación.',
  },
  {
    q: 'Mi empresa es pequeña, ¿realmente necesito un Cyber SOC?',
    a: 'Los ciberdelincuentes automatizan ataques masivos: no buscan "tu" empresa, buscan cualquier puerta abierta, y las empresas pequeñas suelen ser las más expuestas. El SOC gestionado cierra esa puerta con un costo accesible.',
  },
];

const serviceSchema = {
  '@type': 'Service',
  name: 'SOC as a Service',
  serviceType: 'Centro de Operaciones de Ciberseguridad gestionado',
  provider: { '@id': `${SITE.url}/#organization` },
  areaServed: 'Colombia',
  description,
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Capacidades del Cyber SOC',
    itemListElement: CAPACIDADES.map((s) => ({
      '@type': 'Offer',
      itemOffered: { '@type': 'Service', name: s.nombre },
    })),
  },
};
---

<BaseLayout
  {title}
  {description}
  breadcrumbs={[
    { name: 'Inicio', href: '/' },
    { name: 'SOC', href: '/soc' },
  ]}
  schemas={[serviceSchema]}
>
  <!-- HERO -->
  <section class="bg-blueprint bg-hero-mesh relative overflow-hidden border-b border-frost-200">
    <div class="mx-auto grid max-w-7xl items-center gap-12 px-4 pb-16 pt-14 sm:px-6 lg:grid-cols-[1.15fr_1fr] lg:pb-24 lg:pt-20">
      <div class="animate-rise">
        <nav class="text-sm text-ink-mute" aria-label="Miga de pan">
          <a href="/" class="hover:text-mid-600">Inicio</a>
          <span class="mx-2">/</span>
          <span class="font-medium text-cold-600">SOC</span>
        </nav>
        <h1 class="font-display mt-5 text-5xl leading-[0.95] text-ink sm:text-6xl lg:text-7xl">
          <span class="text-brand-gradient">SOC as a Service</span> en Colombia
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-soft">
          Nuestro Cyber SOC monitorea, previene, mitiga y responde a amenazas 24/7: SIEM, SOAR, threat hunting y un CSIRT operativo que
          neutraliza los ataques antes de que se conviertan en problemas.
        </p>
        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a
            href="/contacto"
            class="rounded-xl bg-mid-500 px-8 py-4 text-center font-semibold text-white shadow-[0_8px_30px_rgb(0_115_255/0.35)] transition-all hover:-translate-y-0.5 hover:bg-mid-600"
          >
            Habla con un experto
          </a>
          <a
            href="/ciberseguridad"
            class="rounded-xl border border-frost-300 bg-white/70 px-8 py-4 text-center font-semibold text-cold-600 backdrop-blur transition-colors hover:border-mid-400 hover:text-mid-600"
          >
            Ver ciberseguridad administrada
          </a>
        </div>
      </div>
      <BrandImage
        src="/images/heros/soc-analista.webp"
        alt="Analista del SOC de LumaCloud monitoreando amenazas desde un laptop en un datacenter"
        width={1280}
        height={800}
        overlay
        priority
        class="animate-rise [animation-delay:0.15s]"
      />
    </div>
  </section>

  <!-- CAPACIDADES -->
  <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6">
    <p class="text-center mono-label text-mid-500">Stack tecnológico del Cyber SOC</p>
    <h2 class="font-display mt-3 text-center text-4xl text-cold-600 sm:text-5xl">Capas de defensa trabajando en conjunto</h2>
    <div class="mx-auto mt-3 w-16 brand-rule"></div>

    <div class="scroll-reveal mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        CAPACIDADES.map((s) => (
          <div class="card-brand p-7">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br from-cold-600 to-mid-500 text-white">
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M10 2 3 5.5v5c0 4 3 6.5 7 7.5 4-1 7-3.5 7-7.5v-5L10 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                <path d="M7 10l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <h3 class="mt-5 text-lg font-bold text-ink">{s.nombre}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-mute">{s.texto}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- CÓMO RESPONDE / DETALLE -->
  <section class="bg-blueprint bg-frost-50 py-20">
    <div class="mx-auto grid max-w-7xl items-center gap-12 px-4 sm:px-6 lg:grid-cols-2">
      <div class="scroll-reveal">
        <h2 class="font-display text-4xl text-cold-600 sm:text-5xl">Así se detiene un ataque en minutos, no en días</h2>
        <div class="mt-3 w-16 brand-rule"></div>
        <div class="mt-6 space-y-4 text-base leading-relaxed text-ink-soft">
          <p>
            Imagina que un empleado abre un archivo infectado con ransomware que el antivirus no detectó. El SIEM identifica el
            comportamiento anómalo, cruza el hash del archivo con la inteligencia de VirusTotal y el SOAR responde de inmediato: aísla el
            equipo de la red, elimina el correo de los demás buzones y bloquea la IP maliciosa en el firewall Fortinet.
          </p>
          <p>
            Detrás de la automatización hay un equipo humano: analistas en modalidad 7x24 y un CSIRT operativo que toma el control del
            incidente, investiga y documenta la evidencia.
          </p>
          <p>
            Y la inteligencia no para: usamos IA como multiplicador de fuerza (Google Gemini) y un veredicto unificado que cruza datos de
            Google, Mandiant y VirusTotal para tomar decisiones confiables sobre cada alerta.
          </p>
        </div>
        <ul class="mt-8 space-y-3">
          {
            [
              'Monitoreo continuo 24/7: la seguridad no descansa y nosotros tampoco',
              'Respuesta automatizada con SOAR y control humano del CSIRT',
              'Veredicto unificado: Google + Mandiant + VirusTotal',
              'Reportes detallados para auditorías y cumplimiento normativo',
            ].map((b) => (
              <li class="flex items-start gap-3 text-ink">
                <span class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-mid-500 to-sky-500 text-white">
                  <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                    <path d="M2 6.5 4.5 9 10 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
                <span class="text-[0.95rem] font-medium">{b}</span>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="space-y-6">
        <BrandImage
          src="/images/heros/ciberseguridad-candado.webp"
          alt="Ciberseguridad empresarial: candado sobre un circuito digital"
          width={1280}
          height={800}
          overlay
          class="scroll-reveal"
        />
        <div class="card-brand p-7">
          <p class="font-display text-2xl text-cold-600">Más allá del monitoreo</p>
          <p class="mt-2 text-sm leading-relaxed text-ink-mute">
            Con threat hunting no esperamos la alerta: nuestros analistas buscan indicadores de compromiso en tus logs — conexiones
            sospechosas, comandos inusuales, tráfico raro — para descubrir ataques silenciosos antes de que generen impacto.
          </p>
          <a href="/ciberseguridad" class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-mid-500 hover:text-mid-600">
            Complementa tu defensa con EDR y DLP
            <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M2 8h11M9 3l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ENLACES DE SILO -->
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6">
    <h2 class="font-display text-3xl text-cold-600 sm:text-4xl">El SOC es una pieza: completa tu estrategia</h2>
    <div class="mt-8 grid gap-5 sm:grid-cols-3">
      {
        [
          {
            href: '/ciberseguridad',
            label: 'Ciberseguridad administrada',
            desc: 'Antivirus EDR, DLP, seguridad perimetral, WAF y email security en una sola plataforma.',
          },
          {
            href: '/cumplimiento/iso-27001',
            label: 'Cumplimiento ISO 27001',
            desc: 'El monitoreo del SOC alimenta los controles técnicos que exige la norma.',
          },
          {
            href: '/cumplimiento/ley-1581',
            label: 'Cumplimiento Ley 1581',
            desc: 'Protege los datos personales que tratas y responde a incidentes como lo exige la ley.',
          },
        ].map((l) => (
          <a href={l.href} class="card-brand group p-7">
            <h3 class="font-bold text-ink group-hover:text-mid-600">{l.label}</h3>
            <p class="mt-2 text-sm text-ink-mute">{l.desc}</p>
            <span class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-mid-500">
              Ver más
              <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M2 8h11M9 3l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <FAQSection faqs={FAQS} />
  <CTASection
    title="Elimina tus puntos ciegos"
    text="Cuéntanos cómo está tu operación hoy y te mostramos qué vería nuestro Cyber SOC: monitoreo 24/7, detección con IA y respuesta inmediata."
    ctaLabel="Habla con un experto"
  />
</BaseLayout>
