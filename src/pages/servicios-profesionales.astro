---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BrandImage from '@/components/BrandImage.astro';
import CTASection from '@/components/CTASection.astro';
import FAQSection from '@/components/FAQSection.astro';
import { SITE } from '@/lib/site';

const title = 'Servicios Profesionales TI | LumaCloud';
const description =
  'Servicios profesionales TI en Colombia: administración de bases de datos, infraestructura, sistemas operativos, ciberseguridad y hacking ético.';

const SERVICIOS = [
  {
    nombre: 'Administración de bases de datos',
    texto:
      'Garantizamos la integridad, rendimiento y seguridad de tus datos más críticos: implementación, mantenimiento, optimización y recuperación, con soporte continuo de nuestro equipo.',
  },
  {
    nombre: 'Infraestructura',
    texto:
      'Gestionamos los elementos que soportan tu operación — servidores, almacenamiento y redes de comunicación — para asegurar eficiencia operativa, escalabilidad y continuidad del negocio.',
  },
  {
    nombre: 'Sistemas operativos',
    texto:
      'Administración especializada: gestión de parches y actualizaciones, configuración correcta y monitoreo continuo para prevenir y resolver problemas rápidamente.',
  },
  {
    nombre: 'Ciberseguridad',
    texto:
      'Protegemos tus sistemas, redes y datos frente a ataques digitales con firewalls, antivirus, cifrado de datos, gestión de seguridad perimetral y formación de empleados.',
  },
  {
    nombre: 'Hacking ético',
    texto:
      'Nuestros expertos simulan ataques reales para identificar vulnerabilidades en tu red, aplicaciones y sistemas antes de que los ciberdelincuentes las exploten.',
  },
  {
    nombre: 'Hardening, tuning y monitoreo',
    texto:
      'Endurecemos tus sistemas para reducir su superficie de ataque, los afinamos para un rendimiento óptimo y los monitoreamos en tiempo real para detectar problemas de forma proactiva.',
  },
];

const FAQS = [
  {
    q: '¿Qué incluyen los servicios profesionales de LumaCloud?',
    a: 'Administración de bases de datos, gestión de infraestructura, administración de sistemas operativos, ciberseguridad, hacking ético y servicios complementarios de hardening, tuning y monitoreo de sistemas.',
  },
  {
    q: '¿Qué es el hacking ético y para qué sirve?',
    a: 'Es el uso de técnicas y herramientas de hacking por parte de profesionales de la seguridad para evaluar la robustez de tus sistemas de TI. Nuestros expertos, actuando desde la perspectiva de un atacante, buscan vulnerabilidades en tu red, aplicaciones y sistemas, simulando ataques para poner a prueba tus defensas antes de que lo haga un ciberdelincuente.',
  },
  {
    q: '¿Qué es el hardening de sistemas?',
    a: 'Es el proceso de fortalecer tu infraestructura IT para reducir su superficie de ataque: ajustamos y configuramos sistemas operativos, aplicaciones y redes para eliminar puntos débiles y cerrar posibles brechas de entrada. Además de mayor seguridad, obtienes sistemas optimizados y alineados con las normativas más exigentes.',
  },
  {
    q: '¿En qué consiste el tuning de sistemas?',
    a: 'Es el ajuste y configuración de sistemas operativos, bases de datos, servidores y aplicaciones para mejorar su rendimiento y eficiencia: menores tiempos de respuesta, mejor experiencia de usuario y un uso más eficaz de tus recursos IT.',
  },
  {
    q: '¿El soporte está disponible fuera del horario laboral?',
    a: 'Sí. Nuestro equipo de expertos, arquitectos y administradores está en operación continua 24/7, disponible para asistirte en cualquier necesidad relacionada con tu infraestructura.',
  },
];

const serviceSchema = {
  '@type': 'Service',
  name: 'Servicios profesionales TI',
  serviceType: 'Servicios profesionales de TI',
  provider: { '@id': `${SITE.url}/#organization` },
  areaServed: 'Colombia',
  description,
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Servicios profesionales',
    itemListElement: SERVICIOS.map((s) => ({
      '@type': 'Offer',
      itemOffered: { '@type': 'Service', name: s.nombre },
    })),
  },
};
---

<BaseLayout
  {title}
  {description}
  breadcrumbs={[
    { name: 'Inicio', href: '/' },
    { name: 'Servicios profesionales', href: '/servicios-profesionales' },
  ]}
  schemas={[serviceSchema]}
>
  <!-- HERO -->
  <section class="bg-blueprint bg-hero-mesh relative overflow-hidden border-b border-frost-200">
    <div class="mx-auto grid max-w-7xl items-center gap-12 px-4 pb-16 pt-14 sm:px-6 lg:grid-cols-[1.15fr_1fr] lg:pb-24 lg:pt-20">
      <div class="animate-rise">
        <nav class="text-sm text-ink-mute" aria-label="Miga de pan">
          <a href="/" class="hover:text-mid-600">Inicio</a>
          <span class="mx-2">/</span>
          <span class="font-medium text-cold-600">Servicios profesionales</span>
        </nav>
        <h1 class="font-display mt-5 text-5xl leading-[0.95] text-ink sm:text-6xl lg:text-7xl">
          Servicios profesionales <span class="text-brand-gradient">TI para tu empresa</span>
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-soft">
          Tu infraestructura en manos expertas: administración de bases de datos, infraestructura, sistemas operativos, ciberseguridad y
          hacking ético. Un enfoque personalizado para que operes con confianza y seguridad.
        </p>
        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a
            href="/contacto"
            class="rounded-xl bg-mid-500 px-8 py-4 text-center font-semibold text-white shadow-[0_8px_30px_rgb(0_115_255/0.35)] transition-all hover:-translate-y-0.5 hover:bg-mid-600"
          >
            Habla con un experto
          </a>
          <a
            href="/ciberseguridad"
            class="rounded-xl border border-frost-300 bg-white/70 px-8 py-4 text-center font-semibold text-cold-600 backdrop-blur transition-colors hover:border-mid-400 hover:text-mid-600"
          >
            Ver ciberseguridad administrada
          </a>
        </div>
      </div>
      <BrandImage
        src="/images/heros/servicios-profesionales.webp"
        alt="Ingenieros de LumaCloud administrando infraestructura TI empresarial"
        width={1280}
        height={855}
        overlay
        priority
        class="animate-rise [animation-delay:0.15s]"
      />
    </div>
  </section>

  <!-- SERVICIOS -->
  <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6">
    <p class="text-center text-sm font-semibold uppercase tracking-[0.2em] text-mid-500">Administración integral</p>
    <h2 class="font-display mt-3 text-center text-4xl text-cold-600 sm:text-5xl">Concéntrate en tu negocio, nosotros en tu TI</h2>
    <div class="mx-auto mt-3 w-16 brand-rule"></div>

    <div class="scroll-reveal mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        SERVICIOS.map((s) => (
          <div class="card-brand p-7">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br from-cold-600 to-mid-500 text-white">
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M10 2 3 5.5v5c0 4 3 6.5 7 7.5 4-1 7-3.5 7-7.5v-5L10 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                <path d="M7 10l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <h3 class="mt-5 text-lg font-bold text-ink">{s.nombre}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-mute">{s.texto}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- HACKING ÉTICO EN DETALLE -->
  <section class="bg-blueprint bg-frost-50 py-20">
    <div class="mx-auto grid max-w-7xl items-center gap-12 px-4 sm:px-6 lg:grid-cols-2">
      <div class="scroll-reveal">
        <h2 class="font-display text-4xl text-cold-600 sm:text-5xl">Descubre tus vulnerabilidades antes que los hackers</h2>
        <div class="mt-3 w-16 brand-rule"></div>
        <div class="mt-6 space-y-4 text-base leading-relaxed text-ink-soft">
          <p>
            El servicio de hacking ético de LumaCloud es un análisis profundo y proactivo de tus sistemas para identificar y solucionar
            vulnerabilidades antes de que sean explotadas por ciberdelincuentes.
          </p>
          <p>
            Nuestros especialistas certificados, actuando bajo la perspectiva de un atacante, buscan puntos débiles en tu red,
            aplicaciones y sistemas informáticos, simulando ataques reales para poner a prueba tus defensas. Cada evaluación se adapta a
            las necesidades y especificidades de tu empresa.
          </p>
        </div>
        <ul class="mt-8 space-y-3">
          {
            [
              'Identificación proactiva de vulnerabilidades: descubre y soluciona brechas antes de que las exploten',
              'Mejora continua de la seguridad con insights valiosos para fortalecer tus sistemas',
              'Cumplimiento normativo con las regulaciones de seguridad de datos más estrictas',
              'Concienciación y formación de tu equipo en mejores prácticas de seguridad',
            ].map((b) => (
              <li class="flex items-start gap-3 text-ink">
                <span class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-mid-500 to-sky-500 text-white">
                  <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                    <path d="M2 6.5 4.5 9 10 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
                <span class="text-[0.95rem] font-medium">{b}</span>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="space-y-6">
        <div class="card-brand scroll-reveal p-7">
          <p class="font-display text-2xl text-cold-600">Hardening: menos superficie de ataque</p>
          <p class="mt-2 text-sm leading-relaxed text-ink-mute">
            Fortalecemos tu infraestructura ajustando sistemas operativos, aplicaciones y redes para eliminar puntos débiles y cerrar las
            brechas por donde los atacantes podrían ingresar. Sistemas más seguros y, de paso, optimizados para un mejor rendimiento.
          </p>
        </div>
        <div class="card-brand p-7">
          <p class="font-display text-2xl text-cold-600">Monitoreo: visibilidad completa y en tiempo real</p>
          <p class="mt-2 text-sm leading-relaxed text-ink-mute">
            Observamos y analizamos continuamente el rendimiento de tus servidores, redes y aplicaciones para detectar problemas antes de
            que se conviertan en interrupciones significativas, con informes detallados para tomar decisiones informadas.
          </p>
          <a href="/soc" class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-mid-500 hover:text-mid-600">
            Conoce el monitoreo de seguridad del SOC
            <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M2 8h11M9 3l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ENLACES DE SILO -->
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6">
    <h2 class="font-display text-3xl text-cold-600 sm:text-4xl">Complementa tu operación</h2>
    <div class="mt-8 grid gap-5 sm:grid-cols-3">
      {
        [
          { href: '/ciberseguridad', label: 'Ciberseguridad', desc: 'EDR, DLP, seguridad perimetral, WAF y email security administrados.' },
          { href: '/backup', label: 'Backup y DRP', desc: 'Copias de seguridad y recuperación ante desastres para tus datos críticos.' },
          { href: '/csirt', label: 'CSIRT', desc: 'Equipo de respuesta a incidentes: detección, contención y recuperación.' },
        ].map((l) => (
          <a href={l.href} class="card-brand group p-7">
            <h3 class="font-bold text-ink group-hover:text-mid-600">{l.label}</h3>
            <p class="mt-2 text-sm text-ink-mute">{l.desc}</p>
            <span class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-mid-500">
              Ver más
              <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M2 8h11M9 3l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <FAQSection faqs={FAQS} />
  <CTASection
    title="Pon tu infraestructura en manos expertas"
    text="Cuéntanos qué necesitas — bases de datos, infraestructura, sistemas operativos o seguridad — y diseñamos un plan de administración a tu medida."
    ctaLabel="Habla con un experto"
  />
</BaseLayout>
