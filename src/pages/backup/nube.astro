---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BrandImage from '@/components/BrandImage.astro';
import CTASection from '@/components/CTASection.astro';
import FAQSection from '@/components/FAQSection.astro';
import { SITE } from '@/lib/site';

const title = 'Solución de Backup en la Nube para Empresas | LumaCloud';
const description =
  'Solución de backup en la nube para empresas: copias automáticas fuera de tus instalaciones, almacenamiento inmutable y recuperación remota. Conócela.';

const BENEFICIOS = [
  {
    nombre: 'Copia externa, fuera de tus instalaciones',
    texto:
      'La nube completa tu regla 3-2-1: una tercera copia almacenada en una ubicación secundaria, lejos de cualquier incendio, robo o fallo local que afecte tu oficina.',
  },
  {
    nombre: 'Almacenamiento inmutable',
    texto:
      'Define un período en el que tus copias no se pueden modificar ni eliminar. Si el ransomware cifra tu red, tus respaldos en la nube permanecen intactos.',
  },
  {
    nombre: 'Recuperación remota',
    texto:
      'Ante una pérdida de datos, remediamos y restauramos rápidamente datos y sistemas de forma remota, con poco o ningún tiempo de inactividad.',
  },
  {
    nombre: 'Automatización sin errores humanos',
    texto:
      'Las copias se ejecutan solas, según la programación que definimos contigo. Menos errores humanos y más tiempo para tu equipo.',
  },
  {
    nombre: 'Protección de datos continua',
    texto:
      'No solo copias diarias: protección de datos continua con antimalware basado en comportamiento y firmas, para que la amenaza no viaje con tu backup.',
  },
  {
    nombre: 'Sin costos ocultos',
    texto:
      'Transacciones ilimitadas desde y hacia LumaCloud sin costo adicional, y migración gratuita para que empezar no te cueste nada.',
  },
];

const FAQS = [
  {
    q: '¿Por qué hacer backup en la nube y no solo en mis servidores locales?',
    a: 'Porque un backup local comparte los mismos riesgos que tus datos: un incendio, un robo o un ransomware que cifre tu red puede afectar también tus copias. La nube te da esa tercera copia externa de la regla 3-2-1, en una ubicación secundaria y con almacenamiento inmutable.',
  },
  {
    q: '¿Qué son el RTO y el RPO?',
    a: 'El RTO (Recovery Time Objective) es el tiempo máximo que tu operación puede estar detenida antes de recuperarse; el RPO (Recovery Point Objective) es cuántos datos puedes permitirte perder desde la última copia. Con programación de backups adaptada a tu negocio y recuperación remota, ajustamos ambos a lo que tu operación realmente necesita.',
  },
  {
    q: '¿Dónde quedan almacenados mis datos?',
    a: 'En datacenters TIER III y IV con arquitectura local en Colombia, lo que facilita la recuperación rápida y el cumplimiento de los requisitos de tu industria.',
  },
  {
    q: '¿El ransomware puede afectar mis copias en la nube?',
    a: 'Con el almacenamiento inmutable, no: se establece un período de tiempo en el que los datos no se pueden modificar ni eliminar. Además, el proceso de protección integra defensas proactivas contra ransomware y análisis antimalware.',
  },
  {
    q: '¿Cuánto cuesta migrar mis backups actuales a LumaCloud?',
    a: 'La migración es gratuita. Y una vez operando, las transacciones desde y hacia LumaCloud son ilimitadas y sin costo adicional, con soporte 24/7 incluido.',
  },
];

const serviceSchema = {
  '@type': 'Service',
  name: 'Solución de backup en la nube para empresas',
  serviceType: 'Backup en la nube',
  provider: { '@id': `${SITE.url}/#organization` },
  areaServed: 'Colombia',
  description,
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Beneficios del backup en la nube',
    itemListElement: BENEFICIOS.map((s) => ({
      '@type': 'Offer',
      itemOffered: { '@type': 'Service', name: s.nombre },
    })),
  },
};
---

<BaseLayout
  {title}
  {description}
  breadcrumbs={[
    { name: 'Inicio', href: '/' },
    { name: 'Backup', href: '/backup' },
    { name: 'Backup en la nube', href: '/backup/nube' },
  ]}
  schemas={[serviceSchema]}
>
  <!-- HERO -->
  <section class="bg-blueprint bg-hero-mesh relative overflow-hidden border-b border-frost-200">
    <div class="mx-auto grid max-w-7xl items-center gap-12 px-4 pb-16 pt-14 sm:px-6 lg:grid-cols-[1.15fr_1fr] lg:pb-24 lg:pt-20">
      <div class="animate-rise">
        <nav class="text-sm text-ink-mute" aria-label="Miga de pan">
          <a href="/" class="hover:text-mid-600">Inicio</a>
          <span class="mx-2">/</span>
          <a href="/backup" class="hover:text-mid-600">Backup</a>
          <span class="mx-2">/</span>
          <span class="font-medium text-cold-600">Backup en la nube</span>
        </nav>
        <h1 class="font-display mt-5 text-5xl leading-[0.95] text-ink sm:text-6xl lg:text-7xl">
          Solución de <span class="text-brand-gradient">backup en la nube</span> para tu empresa
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-soft">
          Tu backup local comparte los riesgos de tu oficina. Lleva tus copias a la nube: almacenamiento inmutable, recuperación remota con
          poco o ningún tiempo de inactividad y datacenters TIER III y IV en Colombia.
        </p>
        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a
            href="/contacto"
            class="rounded-xl bg-mid-500 px-8 py-4 text-center font-semibold text-white shadow-[0_8px_30px_rgb(0_115_255/0.35)] transition-all hover:-translate-y-0.5 hover:bg-mid-600"
          >
            Migra tu backup gratis
          </a>
          <a
            href="/backup"
            class="rounded-xl border border-frost-300 bg-white/70 px-8 py-4 text-center font-semibold text-cold-600 backdrop-blur transition-colors hover:border-mid-400 hover:text-mid-600"
          >
            Ver todo el servicio de backup
          </a>
        </div>
      </div>
      <BrandImage
        src="/images/heros/backup-nube.webp"
        alt="Interfaz de una solución de backup en la nube para empresas"
        width={1280}
        height={853}
        overlay
        priority
        class="animate-rise [animation-delay:0.15s]"
      />
    </div>
  </section>

  <!-- BENEFICIOS -->
  <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6">
    <p class="text-center mono-label text-mid-500">Nube vs. local</p>
    <h2 class="font-display mt-3 text-center text-4xl text-cold-600 sm:text-5xl">Por qué respaldar en la nube</h2>
    <div class="mx-auto mt-3 w-16 brand-rule"></div>

    <div class="scroll-reveal mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        BENEFICIOS.map((s) => (
          <div class="card-brand p-7">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br from-cold-600 to-mid-500 text-white">
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M6 14a3.5 3.5 0 0 1-.5-6.965A4.5 4.5 0 0 1 14.2 8.2 3 3 0 0 1 14 14H6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                <path d="M10 9v4M8 11.5 10 13l2-1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <h3 class="mt-5 text-lg font-bold text-ink">{s.nombre}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-mute">{s.texto}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- DETALLE: RTO / RPO -->
  <section class="bg-blueprint bg-frost-50 py-20">
    <div class="mx-auto grid max-w-7xl items-center gap-12 px-4 sm:px-6 lg:grid-cols-2">
      <div class="scroll-reveal">
        <h2 class="font-display text-4xl text-cold-600 sm:text-5xl">RTO y RPO: las dos preguntas que definen tu backup</h2>
        <div class="mt-3 w-16 brand-rule"></div>
        <div class="mt-6 space-y-4 text-base leading-relaxed text-ink-soft">
          <p>
            ¿Puedes imaginar el impacto de perder los datos de un día, una semana o incluso un año por una estrategia inadecuada o poco
            frecuente de copias de seguridad? Eso es el RPO: cuántos datos puedes permitirte perder. Y el RTO responde la otra pregunta:
            cuánto tiempo puede estar detenida tu operación.
          </p>
          <p>
            En la nube de LumaCloud ambos se ajustan a tu negocio: los programas de respaldo son diferentes para cada empresa y se adaptan a
            tus necesidades a lo largo del tiempo, mientras la recuperación remota restaura datos y sistemas con poco o ningún tiempo de
            inactividad.
          </p>
          <p>
            Y si tu operación no tolera interrupciones, complementamos el backup con replicación en tiempo real y un DRP personalizado: si
            tu servidor principal falla, uno secundario toma su lugar automáticamente.
          </p>
        </div>
        <ul class="mt-8 space-y-3">
          {
            [
              'Programación de backups adaptada a tu operación',
              'Pruebas de control rutinarias: sabrás que tu recuperación funciona antes de necesitarla',
              'Sincronización y uso compartido de archivos de forma segura',
              'Replicación en tiempo real para sistemas críticos',
            ].map((b) => (
              <li class="flex items-start gap-3 text-ink">
                <span class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-mid-500 to-sky-500 text-white">
                  <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                    <path d="M2 6.5 4.5 9 10 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
                <span class="text-[0.95rem] font-medium">{b}</span>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="space-y-6">
        <BrandImage
          src="/images/heros/cloud-datacenter.webp"
          alt="Infraestructura de nube en datacenter donde se replican las copias de seguridad"
          width={700}
          height={451}
          overlay
          class="scroll-reveal"
        />
        <div class="card-brand p-7">
          <p class="font-display text-2xl text-cold-600">¿Sabías que…?</p>
          <p class="mt-2 text-sm leading-relaxed text-ink-mute">
            Todo lo que necesita un ciberdelincuente es un sistema desactualizado, una URL maliciosa o un archivo infectado para cifrar tu
            red. Con copias inmutables en la nube, tu backup queda fuera de su alcance.
          </p>
          <a href="/ciberseguridad" class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-mid-500 hover:text-mid-600">
            Conoce la ciberprotección completa
            <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M2 8h11M9 3l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ENLACES DE SILO -->
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6">
    <h2 class="font-display text-3xl text-cold-600 sm:text-4xl">Completa tu estrategia de protección</h2>
    <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        [
          { href: '/backup', label: 'Backup empresarial', desc: 'La visión completa: backup 3-2-1, DRP y replicación para tu continuidad.' },
          { href: '/backup/baas', label: 'Backup as a Service (BaaS)', desc: 'Deja el respaldo en manos de expertos, con soporte 24/7 y costo mensual asequible.' },
          { href: '/ciberseguridad', label: 'Ciberseguridad', desc: 'EDR, DLP y email security para detener las amenazas antes de que entren.' },
          { href: '/soc', label: 'SOC 24/7', desc: 'Monitoreo continuo y respuesta a incidentes sobre toda tu infraestructura.' },
        ].map((l) => (
          <a href={l.href} class="card-brand group p-7">
            <h3 class="font-bold text-ink group-hover:text-mid-600">{l.label}</h3>
            <p class="mt-2 text-sm text-ink-mute">{l.desc}</p>
            <span class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-mid-500">
              Ver más
              <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M2 8h11M9 3l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <FAQSection faqs={FAQS} />
  <CTASection
    title="Lleva tu backup a la nube sin costo de entrada"
    text="La migración es gratuita y las transacciones son ilimitadas. Cuéntanos cómo respaldas hoy y te proponemos una estrategia en la nube a tu medida."
    ctaLabel="Solicita tu migración gratuita"
  />
</BaseLayout>
