---
import Layout from '@/layouts/Layout.astro';
---
<Layout title="Página no encontrada | LumaCloud">
  <section class="max-w-xl mx-auto px-4 py-32 text-center">
    <h1 class="text-6xl font-bold text-brand-500 mb-4">404</h1>
    <p class="text-xl text-gray-600 mb-8">Esta página no existe. Puede que haya sido movida o eliminada.</p>
    <a href="/" class="bg-brand-500 text-white px-8 py-3 rounded-lg font-semibold hover:bg-brand-600 transition">
      Volver al inicio →
    </a>
  </section>
</Layout>
