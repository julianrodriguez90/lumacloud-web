---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/lib/site';

const title = 'Página no encontrada | LumaCloud';
const description = 'La página que buscas no existe o cambió de lugar. Vuelve al inicio o explora nuestros servicios de ciberseguridad y nube.';

const ENLACES = [
  { href: '/', label: 'Inicio', desc: 'La puerta de entrada a todo LumaCloud.' },
  { href: '/ciberseguridad', label: 'Ciberseguridad', desc: 'EDR, DLP, seguridad perimetral, WAF y email security.' },
  { href: '/blog', label: 'Blog', desc: 'Análisis de amenazas y guías prácticas de seguridad.' },
  { href: '/contacto', label: 'Contacto', desc: 'Habla con un experto y agenda tu diagnóstico gratuito.' },
  { href: '/herramientas/calculadora-rto-rpo', label: 'Calculadora RTO/RPO', desc: 'Descubre qué estrategia de backup necesita tu empresa.' },
  { href: '/herramientas/evaluador-iso-27001', label: 'Evaluador ISO 27001', desc: 'Mide tu preparación frente al estándar en 10 preguntas.' },
];
---

<BaseLayout {title} {description} noindex>
  <section class="bg-blueprint bg-hero-mesh relative overflow-hidden border-b border-frost-200">
    <div class="mx-auto max-w-7xl px-4 pb-16 pt-16 text-center sm:px-6 lg:pb-24 lg:pt-24">
      <div class="animate-rise mx-auto max-w-2xl">
        <p class="font-display text-8xl leading-none sm:text-9xl">
          <span class="text-brand-gradient">404</span>
        </p>
        <h1 class="font-display mt-4 text-4xl leading-[0.95] text-ink sm:text-5xl">Esta página se perdió en la nube</h1>
        <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-ink-soft">
          La dirección que buscas no existe o cambió de lugar. Tranquilo: a diferencia de tus datos con nuestro backup, esta página no tiene
          punto de recuperación — pero sí tienes varios caminos de vuelta.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="/"
            class="w-full rounded-xl bg-mid-500 px-8 py-4 text-center font-semibold text-white shadow-[0_8px_30px_rgb(0_115_255/0.35)] transition-all hover:-translate-y-0.5 hover:bg-mid-600 sm:w-auto"
          >
            Volver al inicio
          </a>
          <a
            href="/contacto"
            class="w-full rounded-xl border border-frost-300 bg-white/70 px-8 py-4 text-center font-semibold text-cold-600 backdrop-blur transition-colors hover:border-mid-400 hover:text-mid-600 sm:w-auto"
          >
            Habla con un experto
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:py-20">
    <h2 class="font-display text-center text-3xl text-cold-600 sm:text-4xl">Quizás buscabas esto</h2>
    <div class="mx-auto mt-3 w-16 brand-rule"></div>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        ENLACES.map((l) => (
          <a href={l.href} class="card-brand group p-7">
            <h3 class="font-bold text-ink group-hover:text-mid-600">{l.label}</h3>
            <p class="mt-2 text-sm text-ink-mute">{l.desc}</p>
            <span class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-mid-500">
              Ir ahora
              <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M2 8h11M9 3l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          </a>
        ))
      }
    </div>

    <p class="mt-12 text-center text-sm text-ink-mute">
      ¿Llegaste aquí desde un enlace nuestro? Avísanos a
      <a href={`mailto:${SITE.email}`} class="font-semibold text-mid-500 hover:text-mid-600">{SITE.email}</a> y lo corregimos.
    </p>
  </section>
</BaseLayout>
