---
import Layout from '@/layouts/Layout.astro';
const params = Astro.url.searchParams;
const silo    = params.get('utm_campaign') ?? '';
const tool    = params.get('utm_content')  ?? '';
---
<Layout
  title="Contacto | LumaCloud"
  description="Habla con un experto en ciberseguridad y nube. LumaCloud Colombia — respuesta en menos de 24 horas."
>
  <section class="max-w-2xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold mb-2">Habla con un experto</h1>
    <p class="text-gray-600 mb-8">Cuéntanos sobre tu empresa y te contactamos en menos de 24 horas.</p>
    <form name="contacto" method="POST" data-netlify="true"
      class="space-y-5 bg-gray-50 border border-gray-200 rounded-2xl p-8">
      <input type="hidden" name="silo" value={silo} />
      <input type="hidden" name="tool" value={tool} />
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Nombre completo *</label>
        <input name="nombre" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Correo empresarial *</label>
        <input name="email" type="email" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Empresa *</label>
        <input name="empresa" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">¿En qué podemos ayudarte?</label>
        <textarea name="mensaje" rows="4" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"></textarea>
      </div>
      <button type="submit"
        class="w-full bg-brand-500 hover:bg-brand-600 text-white py-3 rounded-lg font-semibold transition">
        Enviar mensaje →
      </button>
    </form>
  </section>
</Layout>
