---
import Layout from '@/layouts/Layout.astro';
import { ctaLink } from '@/lib/appLinks';
const cta = ctaLink('cloud', 'calculadora-migracion');
---
<Layout
  title="Cloud Privado en Colombia | LumaCloud"
  description="Infraestructura cloud privada en Colombia. IaaS, PaaS, migración a la nube y data center propio con alta disponibilidad."
  silo="cloud"
>
  <section class="bg-brand-500 text-white py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl font-bold mb-4">Cloud privado e infraestructura en Colombia</h1>
      <p class="text-lg text-blue-100 mb-8">Nube privada, IaaS y colocation en data center colombiano. Soberanía de datos, baja latencia y soporte local 24/7.</p>
      <a href={cta} class="bg-white text-brand-500 px-8 py-3 rounded-lg font-semibold hover:bg-blue-50 transition">
        Diseña tu arquitectura cloud →
      </a>
    </div>
  </section>
</Layout>
