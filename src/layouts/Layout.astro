---
const {
  title = 'LumaCloud — Ciberseguridad y Nube Empresarial en Colombia',
  description = 'LumaCloud — Ciberseguridad y nube empresarial en Colombia.',
} = Astro.props;
---
<!doctype html>
<html lang="es-CO">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />
  </head>
  <body class="bg-white text-gray-900 font-sans antialiased">
    <header class="sticky top-0 z-50 bg-white border-b border-gray-100 shadow-sm">
      <nav class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
        <a href="/" class="text-xl font-bold text-brand-500">LumaCloud</a>
        <div class="hidden md:flex gap-6 text-sm font-medium">
          <a href="/ciberseguridad">Ciberseguridad</a>
          <a href="/backup">Backup</a>
          <a href="/cloud">Cloud</a>
          <a href="/soc">SOC</a>
        </div>
        <a href="/contacto" class="bg-brand-500 text-white px-4 py-2 rounded-lg text-sm">Hablar con un experto</a>
      </nav>
    </header>
    <main><slot /></main>
  </body>
</html>
