---
/**
 * Radar del SOC — diagrama SVG hecho a mano con animación CSS.
 * Sustituye fotografía stock: se siente comisionado y pesa ~2KB.
 */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg
  class:list={['w-full', className]}
  viewBox="0 0 480 480"
  role="img"
  aria-label="Radar de monitoreo del SOC de LumaCloud detectando amenazas en tiempo real"
>
  <!-- anillos -->
  {[70, 130, 190].map((r) => <circle cx="240" cy="240" r={r} fill="none" stroke="#CDD8E8" stroke-width="1" />)}
  <circle cx="240" cy="240" r="220" fill="none" stroke="#CDD8E8" stroke-width="1" stroke-dasharray="3 6" />
  <!-- ejes -->
  <line x1="240" y1="20" x2="240" y2="460" stroke="#E2E9F3" stroke-width="1" />
  <line x1="20" y1="240" x2="460" y2="240" stroke="#E2E9F3" stroke-width="1" />
  <!-- barrido -->
  <g class="radar-sweep">
    <path d="M240 240 L240 25 A215 215 0 0 1 342 51 Z" fill="url(#sweepGrad)" opacity="0.5" />
    <line x1="240" y1="240" x2="240" y2="25" stroke="#0073FF" stroke-width="1.5" />
  </g>
  <!-- blips de amenazas -->
  <circle class="blink-dot" cx="318" cy="150" r="5" fill="#0073FF" />
  <circle class="blink-dot-slow" cx="150" cy="300" r="4" fill="#27CAFF" />
  <circle class="blink-dot" cx="185" cy="170" r="3.5" fill="#173A87" style="animation-delay: 1.1s" />
  <circle class="blink-dot-slow" cx="330" cy="330" r="4.5" fill="#0073FF" style="animation-delay: 0.6s" />
  <!-- centro -->
  <circle cx="240" cy="240" r="7" fill="#173A87" />
  <circle cx="240" cy="240" r="13" fill="none" stroke="#173A87" stroke-width="1.5" opacity="0.4" />
  <!-- etiquetas técnicas -->
  <g font-family="IBM Plex Mono, monospace" font-size="10" fill="#6B6875" letter-spacing="0.08em">
    <text x="252" y="34">360°</text>
    <text x="252" y="118">SIEM</text>
    <text x="252" y="178">EDR</text>
    <text x="328" y="142">⊕ AMENAZA</text>
    <text x="30" y="456">LUMA CYBERSOC — MONITOREO CONTINUO</text>
    <text x="376" y="456" fill="#0073FF">24/7 ●</text>
  </g>
  <defs>
    <linearGradient id="sweepGrad" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#0073FF" stop-opacity="0.35" />
      <stop offset="1" stop-color="#27CAFF" stop-opacity="0" />
    </linearGradient>
  </defs>
</svg>
