---
import { SERVICES, NAV } from '@/lib/nav';

const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== '/' && path.startsWith(href + '/'));
---

<header class="sticky top-0 z-50 border-b border-frost-200 bg-white/85 backdrop-blur-lg">
  <div class="mx-auto flex h-[72px] max-w-7xl items-center justify-between gap-6 px-4 sm:px-6">
    <a href="/" class="flex shrink-0 items-center" aria-label="LumaCloud — inicio">
      <img src="/images/brand/logo-luma.webp" alt="LumaCloud" width="132" height="63" class="h-11 w-auto" />
    </a>

    <!-- nav escritorio -->
    <nav class="hidden items-center gap-1 lg:flex" aria-label="Principal">
      <div class="group relative">
        <button
          type="button"
          class:list={[
            'flex items-center gap-1 rounded-lg px-3 py-2 text-sm font-medium transition-colors hover:bg-frost-100 hover:text-cold-600',
            SERVICES.some((s) => isActive(s.href)) ? 'text-cold-600' : 'text-ink-soft',
          ]}
          aria-expanded="false"
          aria-haspopup="true"
        >
          Servicios
          <svg class="h-3.5 w-3.5 transition-transform group-hover:rotate-180" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
        <!-- mega-menú -->
        <div
          class="invisible absolute left-1/2 top-full w-[620px] -translate-x-1/2 pt-3 opacity-0 transition-all duration-200 group-focus-within:visible group-focus-within:opacity-100 group-hover:visible group-hover:opacity-100"
        >
          <div class="overflow-hidden rounded-2xl border border-frost-200 bg-white shadow-card-hover">
            <div class="brand-rule"></div>
            <div class="grid grid-cols-2 gap-1 p-3">
              {
                SERVICES.map((s) => (
                  <a href={s.href} class="group/item rounded-xl px-4 py-3 transition-colors hover:bg-frost-50">
                    <span class="block text-sm font-semibold text-ink group-hover/item:text-mid-600">{s.label}</span>
                    <span class="mt-0.5 block text-xs leading-relaxed text-ink-mute">{s.desc}</span>
                  </a>
                ))
              }
            </div>
          </div>
        </div>
      </div>

      {
        NAV.map((item) => (
          <a
            href={item.href}
            class:list={[
              'rounded-lg px-3 py-2 text-sm font-medium transition-colors hover:bg-frost-100 hover:text-cold-600',
              isActive(item.href) ? 'text-cold-600' : 'text-ink-soft',
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="/contacto"
        class="hidden rounded-xl bg-mid-500 px-5 py-2.5 text-sm font-semibold text-white shadow-[0_4px_14px_rgb(0_115_255/0.35)] transition-all hover:-translate-y-0.5 hover:bg-mid-600 hover:shadow-[0_6px_20px_rgb(0_115_255/0.45)] sm:inline-block"
      >
        Habla con un experto
      </a>

      <!-- menú móvil -->
      <details class="relative lg:hidden">
        <summary
          class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-lg border border-frost-300 text-ink [&::-webkit-details-marker]:hidden"
          aria-label="Abrir menú"
        >
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          </svg>
        </summary>
        <div class="absolute right-0 top-full z-50 mt-3 w-[calc(100vw-2rem)] max-w-sm overflow-hidden rounded-2xl border border-frost-200 bg-white shadow-card-hover">
          <div class="brand-rule"></div>
          <nav class="flex flex-col p-3" aria-label="Menú móvil">
            <span class="px-3 pb-1 pt-2 text-xs font-semibold uppercase tracking-wider text-ink-mute">Servicios</span>
            {
              SERVICES.map((s) => (
                <a href={s.href} class="rounded-lg px-3 py-2 text-sm font-medium text-ink-soft hover:bg-frost-50 hover:text-mid-600">
                  {s.label}
                </a>
              ))
            }
            <div class="my-2 h-px bg-frost-200"></div>
            {
              NAV.map((item) => (
                <a href={item.href} class="rounded-lg px-3 py-2 text-sm font-medium text-ink-soft hover:bg-frost-50 hover:text-mid-600">
                  {item.label}
                </a>
              ))
            }
            <a href="/contacto" class="mt-3 rounded-xl bg-mid-500 px-4 py-3 text-center text-sm font-semibold text-white hover:bg-mid-600">
              Habla con un experto
            </a>
          </nav>
        </div>
      </details>
    </div>
  </div>
</header>
