---
/**
 * Testimonios verificados del WordPress actual — regla E-E-A-T:
 * solo personas reales con nombre y empresa visibles.
 * Layout editorial: cita protagonista + fila de citas secundarias.
 */
import SectionHeader from '@/components/SectionHeader.astro';

interface Props {
  /** número de sección para el encabezado editorial */
  num?: string;
}
const { num = '05' } = Astro.props;

const TESTIMONIOS = [
  {
    nombre: 'Johnnier García',
    empresa: 'QuantumTys',
    cargo: 'Director',
    texto:
      'El acompañamiento de LumaCloud ha sido clave para nuestra operación. Respuesta rápida y soluciones a la medida de lo que necesitamos.',
  },
  {
    nombre: 'David Altamar',
    empresa: 'Takami',
    cargo: 'Coordinador',
    texto:
      'Confiamos nuestra infraestructura a LumaCloud y la estabilidad del servicio ha sido excelente. El soporte siempre está disponible.',
  },
  {
    nombre: 'Juan Miguel Vizcaíno',
    empresa: 'Tecnia Security S.A.S',
    cargo: '',
    texto: 'Un aliado serio en ciberseguridad. La migración fue transparente y el equipo técnico conoce muy bien su trabajo.',
  },
  {
    nombre: 'Natalia Jaimes Martínez',
    empresa: 'All Group Technology SAS',
    cargo: '',
    texto: 'Excelente atención y tiempos de respuesta. Sentimos que trabajamos con un equipo extendido de nuestra propia empresa.',
  },
];

const [principal, ...resto] = TESTIMONIOS;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://lumacloud.co/#organization',
  review: TESTIMONIOS.map((t) => ({
    '@type': 'Review',
    author: { '@type': 'Person', name: t.nombre },
    reviewBody: t.texto,
    itemReviewed: { '@type': 'Organization', name: 'LumaCloud' },
  })),
};
---

<section class="border-y border-frost-200 bg-frost-50 py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6">
    <SectionHeader {num} eyebrow="Clientes verificados" title="Empresas reales, resultados reales" />

    <div class="mt-14 grid gap-10 lg:grid-cols-[1.4fr_1fr]">
      <!-- cita protagonista, escala editorial -->
      <figure class="scroll-reveal corner-ticks border-l-2 border-mid-500 py-2 pl-8 lg:pl-10">
        <blockquote class="text-2xl font-medium leading-snug tracking-tight text-ink sm:text-3xl">
          «{principal.texto}»
        </blockquote>
        <figcaption class="mt-6 flex items-baseline gap-3">
          <span class="font-semibold text-ink">{principal.nombre}</span>
          <span class="mono-label text-ink-mute">{principal.cargo} · {principal.empresa}</span>
        </figcaption>
      </figure>

      <!-- citas secundarias -->
      <div class="grid gap-px overflow-hidden rounded-2xl border border-frost-300 bg-frost-300">
        {
          resto.map((t) => (
            <figure class="bg-white p-6 transition-colors duration-300 hover:bg-frost-50">
              <blockquote class="text-sm leading-relaxed text-ink-soft">{t.texto}</blockquote>
              <figcaption class="mt-3">
                <span class="text-sm font-semibold text-ink">{t.nombre}</span>
                <span class="mono-label ml-2 text-ink-mute">{t.empresa}</span>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
