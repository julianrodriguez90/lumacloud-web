---
/**
 * Encabezado de sección editorial "Swiss-technical": número mono + eyebrow
 * + título display grande, alineado a la izquierda con asimetría deliberada.
 * Reemplaza el patrón genérico de header centrado.
 */
interface Props {
  /** número de sección, ej. "01" */
  num: string;
  eyebrow: string;
  title: string;
  /** subtítulo opcional en una columna angosta */
  lead?: string;
  /** invierte colores para fondos oscuros */
  dark?: boolean;
  class?: string;
}
const { num, eyebrow, title, lead, dark = false, class: className = '' } = Astro.props;
---

<header class:list={['grid gap-6 lg:grid-cols-[auto_1fr] lg:gap-12', className]}>
  <div class="flex items-start gap-4 lg:w-40 lg:flex-col lg:gap-2">
    <span class:list={['mono-data text-sm', dark ? 'text-sky-500' : 'text-mid-500']}>{num} /</span>
    <span class:list={['mono-label pt-0.5', dark ? 'text-white/50' : 'text-ink-mute']}>{eyebrow}</span>
  </div>
  <div>
    <h2 class:list={['font-display max-w-3xl text-4xl leading-[0.95] sm:text-5xl lg:text-6xl', dark ? 'text-white' : 'text-cold-600']}>
      {title}
    </h2>
    {lead && <p class:list={['mt-5 max-w-xl text-base leading-relaxed', dark ? 'text-white/65' : 'text-ink-soft']}>{lead}</p>}
  </div>
</header>
