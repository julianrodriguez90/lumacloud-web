---
/**
 * Diagrama de la solución 360 — capas de defensa apiladas.
 * SVG hecho a mano, estética blueprint con etiquetas mono.
 */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;

const CAPAS = [
  { y: 40, label: 'CIBERSEGURIDAD', sub: 'EDR · DLP · WAF · EMAIL', color: '#173A87' },
  { y: 130, label: 'SOC 24/7', sub: 'SIEM · SOAR · THREAT HUNTING', color: '#0073FF' },
  { y: 220, label: 'BACKUP + DRP', sub: 'REPLICACIÓN · FAILOVER', color: '#27CAFF' },
  { y: 310, label: 'CLOUD', sub: 'TIER III/IV · COLOMBIA', color: '#100E16' },
];
---

<svg class:list={['w-full', className]} viewBox="0 0 520 420" role="img" aria-label="Las cuatro capas de la solución 360 de LumaCloud: ciberseguridad, SOC, backup y cloud">
  {
    CAPAS.map((c, i) => (
      <g>
        <path
          d={`M60 ${c.y + 30} L260 ${c.y - 10} L460 ${c.y + 30} L260 ${c.y + 70} Z`}
          fill="white"
          stroke={c.color}
          stroke-width="1.5"
        />
        <path d={`M60 ${c.y + 30} L260 ${c.y - 10} L460 ${c.y + 30} L260 ${c.y + 70} Z`} fill={c.color} opacity="0.06" />
        <circle class={i === 1 ? 'blink-dot' : ''} cx="260" cy={c.y + 30} r="4" fill={c.color} />
        <line x1="460" y1={c.y + 30} x2="492" y2={c.y + 30} stroke="#CDD8E8" stroke-width="1" />
        <g font-family="IBM Plex Mono, monospace" letter-spacing="0.08em">
          <text x="60" y={c.y - 18} font-size="11" font-weight="500" fill={c.color === '#27CAFF' ? '#00B5F0' : c.color}>
            {`0${i + 1}/ ${c.label}`}
          </text>
          <text x="60" y={c.y - 4} font-size="9" fill="#6B6875">
            {c.sub}
          </text>
        </g>
      </g>
    ))
  }
  <line x1="260" y1="30" x2="260" y2="380" stroke="#CDD8E8" stroke-width="1" stroke-dasharray="2 5" />
  <text x="60" y="408" font-family="IBM Plex Mono, monospace" font-size="10" fill="#6B6875" letter-spacing="0.08em">
    LUMA 360 — UNA SOLA PLATAFORMA, UN SOLO PROVEEDOR
  </text>
</svg>
